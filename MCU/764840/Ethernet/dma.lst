  78          // Returns       :
  79          // Note          :
  80          // ----------------------------------------------------------------------------
  81          void DMA_Init(void)
  82          {
  83   1              // set DMA gap //
  84   1              TDR = DMA_GAP;
  85   1              TCIR = 0x24;
  86   1      
  87   1      } // End of DMA_Init //
  88          
