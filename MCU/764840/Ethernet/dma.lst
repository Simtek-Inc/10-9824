 134          // ----------------------------------------------------------------------------
 135          // Function Name : DMA_GrantXdata
 136          // Purpose       : Use sw-dma doing memory copy. The scope of source and destination
 137          //                              target must     be smaller than 64k sram memory.
 138          //                      If the scope of either source or destination target is large than
 139          //                              64k memory,     the programmers can call DMA_Grant() instead of
 140          //                              this function.
 141          //                      DMA_GrantXdata() can run faster than DMA_Grant() function.
 142          // Params        : 
 143          // Returns       : A address of XDATA memory that point to the next address of
 144          //                              the end address of the scope of destination target.
 145          // Note          :
 146          // ----------------------------------------------------------------------------
 147          byte XDATA* DMA_GrantXdata(byte XDATA* pdest, byte XDATA* psour, uint length)
 148          {
 149   1              byte XDATA                 temp[3];
 150   1              uint XDATA*        ptempshort = (uint XDATA*)&temp[1];
 151   1              byte                       dmatype    = 0;
 152   1      
 153   1              temp[0] = 0;
 154   1              *ptempshort = psour;
 155   1              DMA_WriteReg(SW_DMA_SOUR_ADDR_REG, temp, 3);
 156   1              *ptempshort = pdest;
 157   1              DMA_WriteReg(SW_DMA_TARGET_ADDR_REG, temp, 3);
 158   1              *ptempshort = length;
 159   1              DMA_WriteReg(SW_DMA_BYTE_COUNT_REG, temp + 1, 2);
 160   1      
 161   1              if ((psour >= PBDP->RcvStartAddr) && (psour <= PBDP->RcvEndAddr))
 162   1                      dmatype = DMA_FROM_RPBR;
 163   1              if ((pdest >= PBDP->XmtStartAddr) && (pdest <= PBDP->XmtEndAddr))
 164   1                      dmatype |= DMA_TO_TPBR;
 165   1      
 166   1              temp[0] = (DMA_CMD_GO | dmatype);
 167   1              DMA_WriteReg(SW_DMA_CMD_REG, temp, 1);
 168   1      
 169   1              if (dmatype | DMA_TO_TPBR)
 170   1              {
 171   2                      pdest += length;
 172   2                      if (pdest > PBDP->XmtEndAddr)
 173   2                              pdest -= STOE_XMIT_BUF_SIZE;
 174   2              }
 175   1      
 176   1              // check software dma had completed. //
 177   1              if (dma_CheckStatus())
 178   1                      return pdest;
 179   1              else
 180   1              return 0;
 181   1      
 182   1      } // DMA_GrantXdata //
 183          
 184          #if (DMA_SRAM_RANGE == DMA_COPY_LARGE_THAN_64K)
 185          // ----------------------------------------------------------------------------
 186          // Function Name : DMA_Grant
C51 COMPILER V8.06   DMA                                                                   03/13/2026 10:21:42 PAGE 32  

 187          // Purpose       : Use sw-dma doing memory copy. 
 188          // Params        : 
 189          // Returns       : A address of sram memory that point to the next address of
 190          //                              the end address of the scope of destination target.
 191          // Note          :
 192          // ----------------------------------------------------------------------------
 193          byte* DMA_Grant(byte* pdest, byte* psour, uint length)
 194          {
 195   1              byte  XDATA                sourtemp[4];
 196   1              byte  XDATA                desttemp[4];
 197   1              ulong XDATA*    psourtemplong = (ulong XDATA*)&sourtemp[0];
 198   1              ulong XDATA*    pdesttemplong = (ulong XDATA*)&desttemp[0];
 199   1              uint XDATA*                ptempshort;
 200   1              byte                       dmatype       = 0;
 201   1              byte*                      ptemp;
 202   1      
 203   1              *psourtemplong = (ulong)psour;
 204   1              *pdesttemplong = (ulong)pdest;
 205   1      
 206   1              sourtemp[1]--;  // for Keil C memory type //
 207   1              DMA_WriteReg(SW_DMA_SOUR_ADDR_REG, &sourtemp[1], 3);
 208   1      
 209   1              if (sourtemp[1] == 0)
 210   1              {
 211   2                ptempshort     = (uint XDATA*)&sourtemp[2];
 212   2                if ((*ptempshort >= (uint)PBDP->RcvStartAddr) && (*ptempshort <= (uint)PBDP->RcvEndAddr))
 213   2                              dmatype = DMA_FROM_RPBR;
 214   2              }
 215   1      
 216   1              desttemp[1]--;  // for Keil C memory type //
 217   1              DMA_WriteReg(SW_DMA_TARGET_ADDR_REG, &desttemp[1], 3);
 218   1      
 219   1              if (desttemp[1] == 0)
