  33          // ----------------------------------------------------------------------------
  34          // Function Name : DMA_ReadReg
  35          // Purpose       : Read software-dma register.
  36          // Params        :
  37          // Returns       :
  38          // Note          :
  39          // ----------------------------------------------------------------------------
  40          void DMA_ReadReg(byte regaddr, byte XDATA* pbuf, byte length)
  41          {
  42   1              byte    isr;
  43   1      
  44   1              isr = EA;
  45   1              EA = 0;
  46   1              _nop_();
  47   1              DCIR = regaddr;
  48   1              while (length--)
  49   1                      pbuf[length] = DDR;
  50   1              EA = isr;
  51   1      
  52   1      } // End of DMA_ReadReg //
  53          
  54          // ----------------------------------------------------------------------------
  55          // Function Name : DMA_WriteReg
  56          // Purpose       : Set software-dma register.
  57          // Params        :
  58          // Returns       :
  59          // Note          :
  60          // ----------------------------------------------------------------------------
  61          void DMA_WriteReg(byte regaddr, byte XDATA* pbuf, byte length)
  62          {
C51 COMPILER V8.06   DMA                                                                   03/13/2026 10:21:42 PAGE 30  

  63   1              byte    isr;
  64   1      
  65   1              isr = EA;
  66   1              EA = 0;
  67   1              while (length--)
  68   1                      DDR = pbuf[length];
  69   1              DCIR = regaddr;
  70   1              EA = isr;
  71   1      
  72   1      } // End of STOE_DMA_WriteReg //
  73          
