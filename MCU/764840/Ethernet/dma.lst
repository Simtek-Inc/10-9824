 102          // ----------------------------------------------------------------------------
 103          // Function Name: dma_CheckStatus
 104          // Purpose      : Wait software-dma to complete, and check if dma error happened or not?
 105          // Params       : 
 106          // Returns      : 0 : dma error had happened, so set DMA_FORCE_STOP bit for
 107          //                              dma can work next time.
 108          //                      1 :     dma had completed.
 109          // Note         :
 110          // ----------------------------------------------------------------------------
 111          byte dma_CheckStatus(void)
 112          {
 113   1              byte XDATA      temp;
 114   1      
 115   1              while (1)
 116   1              {
 117   2                      DMA_ReadReg(SW_DMA_CMD_REG, &temp, 1);
 118   2                      if (temp & 0x37)
 119   2                      {
 120   3                              if (temp & DMA_ERROR_BIT)
 121   3                              {
 122   4                                      temp &= ~0x7f;
 123   4                                      temp |= DMA_FORCE_STOP;
 124   4                                      DMA_WriteReg(SW_DMA_CMD_REG, &temp, 1);
C51 COMPILER V8.06   DMA                                                                   03/13/2026 10:21:42 PAGE 31  

 125   4                                      return 0;
 126   4                              }
 127   3                      }
 128   2                      else
 129   2                              return 1;
 130   2              }
 131   1      } // End of dma_CheckStatus //
