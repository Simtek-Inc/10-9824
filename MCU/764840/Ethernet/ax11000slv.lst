 445          /*
 446           *--------------------------------------------------------------------------------
 447           * bool AX11000SLV_SfrRd(unsigned char sfrAddr, unsigned char *sfrData)
 448           * Purpose : Read one byte data from a SFR address.
 449           * Params  : sfrAddr - address of SFR
 450           *           sfrData - one byte data
 451           * Returns : TRUE - successful
 452           * Note:
 453           *--------------------------------------------------------------------------------
 454           */
 455          bool AX11000SLV_SfrRd(unsigned char sfrAddr, unsigned char *sfrData)
 456          {
