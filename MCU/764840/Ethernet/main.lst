 777          void  processSerialData(void)
 778          {
 779   1            byte  len              = 0;   
 780   1            word t16a             = 0;                                                          //
 781   1            byte tmpS;
 782   1      //~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
 783   1      //          the following routines implement the RS422 interface between                  //
 784   1      //          the device and the host system                                                //
 785   1      //~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
 786   1      //          transfer all received into the processing buffer                              //
 787   1      //~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
 788   1              mRxCnt = uart0_GetByteCount();
 789   1              if(mRxCnt >= MinMsgLen)                                                           // check for the
             - minimum message size
 790   1                {
 791   2                memset(&mRxBuf[0], 0, MinMsgLen);                                               // make sure to 
             -zero out the buffer before read from the global receive buffer
 792   2                uart0_GetBuf(&mRxBuf[0], MinMsgLen);                                            // get the messa
             -ge data from the serial receive buffer
 793   2                tmpS = mRxBuf[0];                                                               // get the messa
             -ge length
 794   2                    switch(tmpS)                                                                // find which co
             -mmand
 795   2                      {
 796   3                      case ResetRequest:
 797   3                                                      if(acResetRequest < 0xffff)                                    // make sure that the max number of f
             -irmware requests is not pending
 798   3                              { acResetRequest++; }                                          // trigger a firmwa
             -re action in the main loop
C51 COMPILER V8.06   MAIN                                                                  03/13/2026 10:21:43 PAGE 124 

 799   3                                                      MinMsgLen = DefaultMsgLen;                                        // set the minimum message length 
             -to the default
 800   3                              uart0_RxBufUpdate(MinMsgLen);                                     // remove the messa
             -ge from the recieve buffer
 801   3                          break;
 802   3                      case FirmwareRequest:
 803   3                                                      if(acFirmwareRequest < 0xffff)                                    // make sure that the max number o
             -f firmware requests is not pending
 804   3                              { acFirmwareRequest++; }                                          // trigger a fir
             -mware action in the main loop
 805   3                                                      MinMsgLen = DefaultMsgLen;                                        // set the minimum message length 
             -to the default
 806   3                              uart0_RxBufUpdate(MinMsgLen);                                     // remove the messa
             -ge from the recieve buffer
 807   3                          break;
 808   3                      case StatusRequest:
 809   3                                                      if(acStatusRequest < 0xffff)                                    // make sure that the max number of 
             -firmware requests is not pending
 810   3                              { acStatusRequest++; }                                          // trigger a firmw
             -are action in the main loop
 811   3                                                      MinMsgLen = DefaultMsgLen;                                        // set the minimum message length 
             -to the default
 812   3                              uart0_RxBufUpdate(MinMsgLen);                                     // remove the messa
             -ge from the recieve buffer
 813   3                          break;
 814   3                      case DimmingRequest:
 815   3                              len = m2sDimmingMsgLength;                                                  // 
 816   3                              if(mRxCnt >= len)                                                         // check if the 
             -defined message length matches the received message length
 817   3                              {
 818   4                                                      if(acDimmingRequest < 0xffff)                                     // make sure that the max number o
             -f firmware requests is not pending
 819   4                              { acDimmingRequest++; }                                           // trigger a fir
             -mware action in the main loop
 820   4                                      uart0_GetBuf(&mRxBuf[ix01], len);                                       // get the messa
             -ge data from the serial receive buffer
 821   4                                      memmove(&bufDimmingData[ix02], &mRxBuf[ix02], len-1);                    // copy the new
             - display data into the display data buffer
 822   4                                      uart0_RxBufSet(0,len);                                                  //
 823   4                                      uart0_RxBufUpdate(len);                                                 // remove the me
             -ssage from the recieve buffer
 824   4                                      MinMsgLen = DefaultMsgLen;                                              // set the minim
             -um message length to the default
 825   4                              }
 826   3                              else
 827   3                              {
 828   4                                      MinMsgLen = len;                                                        // set the minim
             -um message length
 829   4                              }//else if(mRxCnt >= FirmwareMsgS0Len)
 830   3                    break;
 831   3                      default   :
 832   3      //                    derror("..ERROR : CB");                                               // let user kn
             -ow that there was an error the command sent was not defined
 833   3                          //StatusData[ix15] |= 0x1C;                                             // add error f
             -lags
 834   3                          MinMsgLen = DefaultMsgLen;                                            // set the minim
             -um message length to the default
 835   3                          uart0_RxBufUpdate(MinMsgLen);                                         // remove the me
             -ssage from the recieve buffer
 836   3                          break;
 837   3                      }
 838   2                      }
