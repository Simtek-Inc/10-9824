           =1 // INCLUDE FILE DECLARATIONS //
           =1 #include "types.h"
           =1 
           =1 // internal phy id address //
           =1 #define PHY_ADDRESS                                     0x10
           =1 #define PHY_INTERNAL                            0
           =1 #define PHY_EXTERNAL                            1
           =1 
           =1 // network type //
           =1 #define AUTO_NEGOTIATION                        0
           =1 #define FIXED_100_FULL                          1
           =1 #define FIXED_100_HALF                          2
           =1 #define FIXED_10_FULL                           3
           =1 #define FIXED_10_HALF                           4
           =1 #define FORCE_EMBEDDED_PHY_10_HALF      5
           =1 
           =1 // NAMING CONSTANT DECLARATIONS //
           =1 // SFR 0xBE definitions //
           =1 #define PHY_READ_REG                            BIT7
           =1 #define PHY_ACCESS_GO                           BIT6
           =1 #define PHY_CMD_ABORT                           0xFF
           =1 
           =1 // MII register definitions //
           =1 #define MII_PHY_CONTROL                         0x00    // control reg
           =1 #define MII_PHY_STATUS                          0x01    // status reg
           =1 #define MII_PHY_OUI                                     0x02    // most of the OUI bits
           =1 #define MII_PHY_MODEL                           0x03    // model/rev bits, and rest of OUI
           =1 #define MII_PHY_ANAR                            0x04    // AN advertisement reg
           =1 #define MII_PHY_ANLPAR                          0x05    // AN Link Partner
           =1 #define MII_PHY_ANER                            0x06    // AN expansion reg
           =1 
           =1 // Bit definitions: MII Control //
           =1 #define CONTROL_RESET                           0x8000  // reset bit in control reg
           =1 #define CONTROL_LOOPBACK                        0x4000  // loopback bit in control reg
           =1 #define CONTROL_10MB                            0x0000  // 10 Mbit
           =1 #define CONTROL_100MB                           0x2000  // 100Mbit
           =1 #define CONTROL_ENABLE_AUTO                     0x1000  // autonegotiate enable
           =1 #define CONTROL_POWER_DOWN                      0x0800
           =1 #define CONTROL_ISOLATE                         0x0400  // islolate bit
           =1 #define CONTROL_START_AUTO                      0x0200  // restart autonegotiate
           =1 #define CONTROL_FULL_DUPLEX                     0x0100
           =1 
           =1 // Bit definitions: Auto-Negotiation Advertisement //
           =1 #define ANAR_PAUSE                                      0x0400  // support pause packets
           =1 #define ANAR_100T4                                      0x0200  // support 100BT4
           =1 #define ANAR_100TXFD                            0x0100  // support 100BTX full duplex
           =1 #define ANAR_100TX                                      0x0080  // support 100BTX half duplex
           =1 #define ANAR_10TFD                                      0x0040  // support 10BT full duplex
           =1 #define ANAR_10T                                        0x0020  // support 10BT half duplex
           =1 #define ANAR_SELECTOR_FIELD                     0x001F  // selector field.
           =1 #define ANAR_SELECTOR_8023                      0x0001
           =1 
           =1 // Bit definitions: Auto-Negotiation Link Partner Ability //
           =1 #define ANLPAR_PAUSE                            0x0400  // support pause packets
           =1 #define ANLPAR_100T4                            0x0200  // support 100BT4
           =1 #define ANLPAR_100TXFD                          0x0100  // support 100BTX full duplex
