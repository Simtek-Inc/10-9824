 323          // name    : NOP                                                                          //
 324          // purpose : create a small runtime delay                                                 //
 325          // params  : the number of times to loop                                                  //
 326          // returns : void                                                                         //
 327          // notes   :                                                                              //
 328          //----------------------------------------------------------------------------------------//
 329          void NOP(uint loop)                                                                       //
 330          {
 331   1            uint i;                                                                             //
 332   1      
 333   1            for (i = 0; i < loop; i++)                                                          //
 334   1             {    _nop_();    }                                                                 //
 335   1      }
