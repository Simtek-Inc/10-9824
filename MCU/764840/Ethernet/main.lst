 337          //----------------------------------------------------------------------------------------
 338          // name    : wrEthTxBuffer(byte ch, uint Count)                                           //
 339          // purpose : write data to the ring buffer to transmit over Ethernet                      //
 340          // params  : Data byte to write, Count of bytes currently in buffer                       //
 341          // returns : updated count of bytes in buffer                                             //
 342          // notes   :                                                                              //
 343          //----------------------------------------------------------------------------------------
 344          uint wrChrEthTxBuffer(byte ch, uint Count)                                                // write data to
             - the ethernet transmit buffer
 345          {
 346   1            EthTxBuffer[EthTxBufIndx] = ch;                                                     // add the data 
             -to the ethernet buffer
 347   1            EthTxBufIndx++;                                                                     // update the et
             -hernet buffer index
 348   1            Count++;                                                                            // update the co
             -unt showing the number of bytes in the buffer
 349   1            if (EthTxBufIndx == EthMaxTxSize)                                                   // check to see 
             -if the index is at the maximum
 350   1              EthTxBufIndx = 0;                                                                 // reset the ind
             -ex to the first byte of the buffer
 351   1            return Count;                                                                       // pass the buff
             -er count back to the calling routine
 352   1      }
 353          
 354          //----------------------------------------------------------------------------------------
 355          // name    : wrStrEthTxBuffer(byte* pData, uint cnt)                                      //
 356          // purpose : write data to the ring buffer to transmit over Ethernet                      //
C51 COMPILER V8.06   MAIN                                                                  03/13/2026 10:21:43 PAGE 115 

 357          // params  : pointer to the data bytes to write, number of bytes to write                 //
 358          // returns : number of bytes sucessfully written into the buffer                          //
 359          // notes   :                                                                              //
 360          //----------------------------------------------------------------------------------------
 361          uint wrStrEthTxBuffer(byte* pData, uint cnt)                                              // write data to
             - the ethernet transmit buffer
 362          {
 363   1            uint TmpCnt;                                                                        //
 364   1            uint offset;                                                                        //
 365   1      
 366   1            if((EthTxBufIndx + cnt) > EthMaxTxSize)                                             // make sure tha
             -t the number of bytes to write added to the number
 367   1            {                                                                                   //  of bytes in 
             -the buffer already is not greater then the buffer
 368   2              offset = EthMaxTxSize - EthTxBufIndx;                                             // find the numb
             -er of bytes that will fit in the buffer before overflow
 369   2              memmove(&EthTxBuffer[EthTxBufIndx], pData, offset);                               // fill the rema
             -inder of the buffer with the given data
 370   2              memmove(&EthTxBuffer[ix01], pData+offset, cnt - offset);                          // add the remai
             -nder of the given data to the begining of the buffer
 371   2              }
 372   1            else                                                                                // else all of t
             -he given data will still fit in the buffer
 373   1              {
 374   2              memmove(&EthTxBuffer[EthTxBufIndx], pData, cnt);                                  // place all of 
             -the given data into the buffer
 375   2              }
 376   1            EthTxBufIndx += cnt;                                                                // make sure tha
             -t the index points at the first empty byte
 377   1            EthTxBufIndx &= EthMaxTxMask;                                                       // mask the inde
             -x to wrap the buffer around into a ring
 378   1            TmpCnt = readEthTxBufCount() + cnt;                                                 // adjust the cu
             -rrent buffer count
 379   1            writeEthTxCount(TmpCnt);
 380   1            return TmpCnt;                                                                      // return the nu
             -mber of bytes in the buffer
 381   1      }
