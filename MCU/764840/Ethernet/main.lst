 395          //----------------------------------------------------------------------------------------
 396          // name    : main_readEthChar(byte* pDat)                                                 //
 397          // purpose : retrieve data from buffer to place in ethernet transmit buffer               //
 398          // params  : pointer to variable to return                                                //
 399          // returns : count of data left in buffer                                                 //
 400          // notes   : this routine replaced GetEthChar defined in main.c.                          //
 401          //----------------------------------------------------------------------------------------
 402          uint main_readEthChar(byte* pDat)                                                         // read a data b
             -yte from the ethernet buffer
 403          {
C51 COMPILER V8.06   MAIN                                                                  03/13/2026 10:21:43 PAGE 116 

 404   1            uint temp;                                                                          //
 405   1            
 406   1            temp = readEthTxBufCount();                                                         // get the curre
             -nt ethernet buffer count
 407   1            if (temp > 0)                                                                       // see if there 
             -are any bytes in the buffer
 408   1              {
 409   2              *pDat = EthTxBuffer[EthTxBufTail];                                                // write the dat
             -a to the location pointed to by the pointer
 410   2              EthTxBufTail++;                                                                   // update the et
             -hernet ring buffer index
 411   2              if (EthTxBufTail == EthMaxTxSize)                                                 // check the ind
             -ex to make sure that the index remains within the buffer space 
 412   2                {  EthTxBufTail = 0;  }                                                         // reset the ind
             -ex to the first byte of the buffer
 413   2              EthTxCount--;                                                                     // update the co
             -unt of the bytes in the buffer
 414   2              return EthTxCount;                                                                // pass the alte
             -red count back to the calling routine
 415   2              }
 416   1            return 0;                                                                           // write the def
             -ault value for the count
 417   1      }
