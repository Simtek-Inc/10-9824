 658          //----------------------------------------------------------------------------------------
 659          ulong processEthernetTraffic(ulong ptc, dls)                                              //
 660          {
 661   1          ulong tc;                                                                             // current time 
             -count
 662   1          byte  linkSpeed = 0;                                                                  //
 663   1          
 664   1          tc              = (uint)SWTIMER_Tick();                                               // get the curre
             -nt timer count
 665   1          if ((tc - ptc) >= TIME_OUT_COUNTER)                                                   // see if the di
             -fference in the curent & last time differs more then the timeout
 666   1            {
 667   2            ptc           = tc;                                                                 // set the last 
             -time to the current time
 668   2            TCPIP_PeriodicCheck();                                                              // check the for
             - any TCPIP traffic
 669   2            }
 670   1          STOE_ProcessInterrupt();                                                              // process all T
             -OE buffers input/output
 671   1          if (MAC_GetInterruptFlag())                                                           // get the data 
             -for this device
 672   1            { linkSpeed   = MAC_ProcessInterruptExt(); }                                        // find the link
             -age speed, and process device traffic
 673   1          if(dls == ON) printd("Ethernet Link Speed = bps\n\r", linkSpeed);                     // display the l
             -inkage speed
 674   1          return ptc;                                                                           // return the cu
             -rrent timer count
 675   1      }
