 579          // name    : printdHex2Bin(byte num)                                                      //
 580          // purpose :                                                                              //
 581          // params  : void                                                                         //
 582          // returns : void                                                                         //
 583          // notes   :                                                                              //
 584          //----------------------------------------------------------------------------------------
 585          void printdHex2Bin(byte num)
 586          {
 587   1        if((num & 0x80) == 0) printd("0");  else printd("1");
 588   1        if((num & 0x40) == 0) printd("0");  else printd("1");
 589   1        if((num & 0x20) == 0) printd("0");  else printd("1");
 590   1        if((num & 0x10) == 0) printd("0");  else printd("1");
 591   1        if((num & 0x08) == 0) printd("0");  else printd("1");
 592   1        if((num & 0x04) == 0) printd("0");  else printd("1");
 593   1        if((num & 0x02) == 0) printd("0");  else printd("1");
 594   1        if((num & 0x01) == 0) printd("0 "); else printd("1 ");
 595   1      }
