             -address to the user debug port
 561   2                                                  (byte) ((ip >> 16) & 0x000000FF),             //
 562   2                                                  (byte) ((ip >> 8)  & 0x000000FF),             //
 563   2                                                  (byte) ( ip        & 0x000000FF));            //
 564   2              }                                                                                 //
 565   1            else                                                                                // the IP was va
             -lid
 566   1              if (ip == 0)                                                                      // check the IP 
             -to see if it is valid
 567   1                {                                                                               //
