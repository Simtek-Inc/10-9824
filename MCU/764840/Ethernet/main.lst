 388          // notes   :                                                                              //
 389          //----------------------------------------------------------------------------------------
 390          void writeEthTxCount(uint TempCount)                                                      // update the gl
             -obal ethernet transmit buffer count
 391          {
 392   1            EthTxCount = TempCount;                                                             // write the new
             - count to the global buffer
 393   1      }
