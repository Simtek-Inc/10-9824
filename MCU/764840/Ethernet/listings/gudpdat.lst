 363          // ---------------------------------------------------------------------------------------//
 364          // name    : GUDPDAT_NewConn                                                              //
 365          // Purpose :                                                                              //
 366          // Params  :                                                                              //
 367          // Returns :                                                                              //
 368          // Note    :                                                                              //
 369          // ---------------------------------------------------------------------------------------//
C51 COMPILER V8.06   GUDPDAT                                                               07/01/2021 16:27:16 PAGE 78  

 370          byte GUDPDAT_NewConn(ulong XDATA* pip, uint remotePort, byte socket)                      //
 371          {
 372   1            byte i;                                                                             //
 373   1      
 374   1            gudpdat_LastConnId = 0;                                                             // make sure the
             - last connection starts off with the first socket
 375   1      
 376   1            if (gudpdat_Conns[gudpdat_LastConnId].State == GUDPDAT_STATE_CONNECTED)             //
 377   1              {
 378   2              gudpdat_Conns[gudpdat_LastConnId].State = GUDPDAT_STATE_FREE;                     //
 379   2              TCPIP_UdpClose(gudpdat_Conns[gudpdat_LastConnId].UdpSocket);                      //
 380   2              }
 381   1            for (i = 0; i < GUDPDAT_MAX_CONNS; i++)                                             //
 382   1              {
 383   2              if (gudpdat_Conns[i].State == GUDPDAT_STATE_FREE)                                 //
 384   2                {
 385   3                GS2E_SetTaskState(GS2E_STATE_UDP_DATA_PROCESS);                                 //
 386   3                gudpdat_Conns[i].State = GUDPDAT_STATE_CONNECTED;                               //
 387   3                gudpdat_Conns[i].Timer = SWTIMER_Tick();                                        //
 388   3                gudpdat_Conns[i].Ip = *pip;                                                     //
 389   3                gudpdat_Conns[i].Port = remotePort;                                             //
 390   3                gudpdat_Conns[i].UdpSocket = socket;                                            //
 391   3                printd("New UDP connection : id=%bu, remotePort=%du, socket=%bu\n\r",           //
 392   3                        i, remotePort, socket);                                                 //
 393   3                gudpdat_LastConnId++;                                                           //
 394   3                gudpdat_LastConnId = gudpdat_LastConnId & 0x03;                                 //
 395   3                return i;                                                                       //
 396   3                }
 397   2              }
 398   1            return GUDPDAT_NO_NEW_CONN;                                                         //
 399   1      } // End of GUDPDAT_NewConn() //
