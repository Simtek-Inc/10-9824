 328   1      
 329   1            gudpdat_UdpClient = FALSE;                                                          //
 330   1            for (i = 0; i < GUDPDAT_MAX_CONNS; i++)                                             //
 331   1              {
 332   2              gudpdat_Conns[i].State = GUDPDAT_STATE_FREE;                                      //
 333   2              gudpdat_Conns[i].UrRxBytes = 0;                                                   //
 334   2              gudpdat_Conns[i].UrTxBytes = 0;                                                   //
 335   2              }
 336   1            gudpdat_LastConnId = 0;                                                             // make sure the
             - last connection starts off with the first socket
 337   1            gudpdat_InterAppId = TCPIP_Bind(GUDPDAT_NewConn, GUDPDAT_Event, GUDPDAT_Receive);   // bind the UDP 
             -functions to the TOE
 338   1            // unicast packet //
 339   1            printd("UDP data ");                                                                // let the user 
             -know the the port is initailized
 340   1              if (gudpdat_InterAppId == TCPIP_NO_NEW_CONN)                                        // check if the bindi
             -ng failed
 341   1              printd("port           : **BINDING ERROR!**\n\r");                                                
             - // let the user know the the port is initailized
 342   1            else
 343   1              {
 344   2              if ((GCONFIG_GetNetwork() & GCONFIG_NETWORK_CLIENT) != GCONFIG_NETWORK_CLIENT)    // is the TOE go
             -ing to setup as a Client or Server
 345   2                {
 346   3                i = TCPIP_UdpListen(localPort, gudpdat_InterAppId);                             // setup the loc
             -al Port
 347   3                if(i == 1)
 348   3                  printd("server port    : %du\n\r",localPort);                                 // set listen so
             -cket completed!
 349   3                else
 350   3                printd("server port    : * BINDING ERROR! *\n\r");                              // set listen so
             -cket FAILED! socket ERROR
 351   3                }
 352   2              else                                                                              //
 353   2                {
 354   3                gudpdat_UdpClient = TRUE;                                                       // set the Clien
             -t flag for the firmware
 355   3                printd("client port      : %du\n\r",localPort);                                 // let the user 
             -know the port is setup as a Client
 356   3                }
 357   2              }
 358   1            gudpdat_TxDatLen = 0;                                                               // initailize th
             -e received data array index to the first cell
 359   1            gudpdat_TxWaitTime = 0;                                                             // initailize th
             -e process timeout
 360   1            gudpdat_EthernetTxTimer = GCONFIG_GetEthernetTxTimer();                             // set the start
             - time
 361   1      } // End of GUDPDAT_Init() //
