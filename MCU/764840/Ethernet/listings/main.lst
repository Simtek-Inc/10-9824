 583          //----------------------------------------------------------------------------------------
 584          // name    : main_readEthChar(byte* pDat)                                                 //
 585          // purpose : retrieve data from buffer to place in ethernet transmit buffer               //
 586          // params  : pointer to variable to return                                                //
 587          // returns : count of data left in buffer                                                 //
 588          // notes   : this routine replaced GetEthChar defined in main.c.                          //
 589          //----------------------------------------------------------------------------------------
 590          uint main_readEthChar(byte* pDat)                                                         // read a data b
             -yte from the ethernet buffer
 591          {
 592   1            uint temp;                                                                          //
 593   1            
 594   1            temp = readEthTxBufCount();                                                         // get the curre
             -nt ethernet buffer count
 595   1            if (temp > 0)                                                                       // see if there 
             -are any bytes in the buffer
 596   1              {
 597   2              *pDat = EthTxBuffer[EthTxBufTail];                                                // write the dat
             -a to the location pointed to by the pointer
 598   2              EthTxBufTail++;                                                                   // update the et
             -hernet ring buffer index
 599   2              if (EthTxBufTail == EthMaxTxSize)                                                 // check the ind
             -ex to make sure that the index remains within the buffer space 
 600   2                {  EthTxBufTail = 0;  }                                                         // reset the ind
             -ex to the first byte of the buffer
 601   2              EthTxCount--;                                                                     // update the co
             -unt of the bytes in the buffer
 602   2              return EthTxCount;                                                                // pass the alte
             -red count back to the calling routine
 603   2              }
 604   1            return 0;                                                                           // write the def
             -ault value for the count
 605   1      }
