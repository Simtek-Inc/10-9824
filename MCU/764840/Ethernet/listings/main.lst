 525          //----------------------------------------------------------------------------------------
 526          // name    : wrEthTxBuffer(byte ch, uint Count)                                           //
 527          // purpose : write data to the ring buffer to transmit over Ethernet                      //
 528          // params  : Data byte to write, Count of bytes currently in buffer                       //
 529          // returns : updated count of bytes in buffer                                             //
 530          // notes   :                                                                              //
 531          //----------------------------------------------------------------------------------------
 532          uint wrChrEthTxBuffer(byte ch, uint Count)                                                // write data to
             - the ethernet transmit buffer
 533          {
 534   1            EthTxBuffer[EthTxBufIndx] = ch;                                                     // add the data 
             -to the ethernet buffer
 535   1            EthTxBufIndx++;                                                                     // update the et
             -hernet buffer index
 536   1            Count++;                                                                            // update the co
             -unt showing the number of bytes in the buffer
 537   1            if (EthTxBufIndx == EthMaxTxSize)                                                   // check to see 
             -if the index is at the maximum
 538   1              EthTxBufIndx = 0;                                                                 // reset the ind
             -ex to the first byte of the buffer
 539   1            return Count;                                                                       // pass the buff
             -er count back to the calling routine
 540   1      }
 541          
 542          //----------------------------------------------------------------------------------------
 543          // name    : wrStrEthTxBuffer(byte* pData, uint cnt)                                      //
 544          // purpose : write data to the ring buffer to transmit over Ethernet                      //
 545          // params  : pointer to the data bytes to write, number of bytes to write                 //
 546          // returns : number of bytes sucessfully written into the buffer                          //
 547          // notes   :                                                                              //
 548          //----------------------------------------------------------------------------------------
 549          uint wrStrEthTxBuffer(byte* pData, uint cnt)                                              // write data to
             - the ethernet transmit buffer
 550          {
 551   1            uint TmpCnt;                                                                        //
 552   1            uint offset;                                                                        //
 553   1      
 554   1            if((EthTxBufIndx + cnt) > EthMaxTxSize)                                             // make sure tha
             -t the number of bytes to write added to the number
 555   1            {                                                                                   //  of bytes in 
             -the buffer already is not greater then the buffer
 556   2              offset = EthMaxTxSize - EthTxBufIndx;                                             // find the numb
             -er of bytes that will fit in the buffer before overflow
 557   2              memmove(&EthTxBuffer[EthTxBufIndx], pData, offset);                               // fill the rema
             -inder of the buffer with the given data
 558   2              memmove(&EthTxBuffer[ix01], pData+offset, cnt - offset);                          // add the remai
             -nder of the given data to the begining of the buffer
 559   2              }
 560   1            else                                                                                // else all of t
             -he given data will still fit in the buffer
 561   1              {
 562   2              memmove(&EthTxBuffer[EthTxBufIndx], pData, cnt);                                  // place all of 
             -the given data into the buffer
C51 COMPILER V8.06   MAIN                                                                  07/01/2021 16:27:13 PAGE 119 

 563   2              }
 564   1            EthTxBufIndx += cnt;                                                                // make sure tha
             -t the index points at the first empty byte
 565   1            EthTxBufIndx &= EthMaxTxMask;                                                       // mask the inde
             -x to wrap the buffer around into a ring
 566   1            TmpCnt = readEthTxBufCount() + cnt;                                                 // adjust the cu
             -rrent buffer count
 567   1            writeEthTxCount(TmpCnt);
 568   1            return TmpCnt;                                                                      // return the nu
             -mber of bytes in the buffer
 569   1      }
