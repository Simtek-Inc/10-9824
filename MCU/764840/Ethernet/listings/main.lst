  88      =2  
  89      =2  // I2C Slave Command //
  90      =2  #define I2C_SLV_SRSFR                   BIT5                    // SFR single read
  91      =2  #define I2C_SLV_SWSFR                   BIT7+BIT5               // SFR single write
  92      =2  #define I2C_SLV_IRSFR                   BIT5+BIT4               // SFR indirect read
  93      =2  #define I2C_SLV_IWSFR                   BIT7+BIT5+BIT4  // SFR indirect write
  94      =2  #define I2C_SLV_BRDM                    BIT6                    // Memory burst read
  95      =2  #define I2C_SLV_BWDM                    BIT7+BIT6               // Memory burst write
  96      =2  
  97      =2  // I2C Master Clock //
  98      =2  #define I2C_FAST_25M                    0x0C    // Fast mode pre-scale at 25M
  99      =2  #define I2C_FAST_50M                    0x18    // Fast mode pre-scale at 50M
 100      =2  #define I2C_FAST_100M                   0x31    // Fast mode pre-scale at 100M
