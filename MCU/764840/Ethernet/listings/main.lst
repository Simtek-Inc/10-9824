 842          // notes   :                                                                              //
 843          //----------------------------------------------------------------------------------------
 844          void UpdateIpSettings(ulong ip)                                                           // Update IP add
             -ress, subnet mask, gateway IP address and DNS IP address
 845          {
 846   1            if (ip > 0)                                                                         // check the IP 
             -to see if it is valid
 847   1              {
 848   2              printd("IP  : %bu.%bu.%bu.%bu\n\r", (byte) ((ip >> 24) & 0x000000FF),             // write the IP 
             -address to the user debug port
 849   2                                                  (byte) ((ip >> 16) & 0x000000FF),             //
 850   2                                                  (byte) ((ip >> 8)  & 0x000000FF),             //
 851   2                                                  (byte) ( ip        & 0x000000FF));            //
 852   2              }
 853   1            else                                                                                // the IP was va
             -lid
 854   1              if (ip == 0)                                                                      // check the IP 
             -to see if it is valid
 855   1                {
 856   2                ulong mask = GCONFIG_GetNetmask();                                              // retrieve the 
             -default net mask
 857   2                ip = GCONFIG_GetServerStaticIP();                                               // retrieve the 
             -static IP
 858   2                TCPIP_SetIPAddr(ip);                                                            // write the def
             -ault IP addess into the DCB
 859   2                STOE_SetIPAddr(ip);                                                             // write the def
             -ault IP addess into the DCB
C51 COMPILER V8.06   MAIN                                                                  07/01/2021 16:27:13 PAGE 125 

 860   2                TCPIP_SetSubnetMask(mask);                                                      // write the def
             -ault net mask into the DCB
 861   2                STOE_SetSubnetMask(mask);                                                       // write the def
             -ault net mask into the DCB
 862   2                }
 863   1            GS2E_Init();                                                                        //
