           =2 #endif
           =2 
           =2 #define TRUE                  1
           =2 #define FALSE                 0
           =2 #define ON                    1
           =2 #define OFF                   0
           =2 #define Client                1
           =2 #define Server                0
           =2 
           =2 // Bit Definitions for Bitwise Operation //
           =2 #define BIT0            0x01
           =2 #define BIT1            0x02
           =2 #define BIT2            0x04
           =2 #define BIT3            0x08
           =2 #define BIT4            0x10
