 573          // purpose : update the count checked by Ethernet process                                 //
 574          // params  : updated count                                                                //
 575          // returns : void                                                                         //
 576          // notes   :                                                                              //
 577          //----------------------------------------------------------------------------------------
 578          void writeEthTxCount(uint TempCount)                                                      // update the gl
             -obal ethernet transmit buffer count
 579          {
 580   1            EthTxCount = TempCount;                                                             // write the new
             - count to the global buffer
 581   1      }
