 866          //----------------------------------------------------------------------------------------
 867          // name    : printdHex2Bin(byte num)
 868          // purpose : 
 869          // params  : void                                                                         //
 870          // returns : void                                                                         //
 871          // notes   :                                                                              //
 872          //----------------------------------------------------------------------------------------
 873          void printdHex2Bin(byte num)
 874          {
 875   1        if((num & 0x80) == 0) printd("0");  else printd("1");
 876   1        if((num & 0x40) == 0) printd("0");  else printd("1");
 877   1        if((num & 0x20) == 0) printd("0");  else printd("1");
 878   1        if((num & 0x10) == 0) printd("0");  else printd("1");
 879   1        if((num & 0x08) == 0) printd("0");  else printd("1");
 880   1        if((num & 0x04) == 0) printd("0");  else printd("1");
 881   1        if((num & 0x02) == 0) printd("0");  else printd("1");
 882   1        if((num & 0x01) == 0) printd("0 "); else printd("1 ");
 883   1      }
