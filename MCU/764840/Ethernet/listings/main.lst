 176          //----------------------------------------------------------------------------------------
 177          // bitcontrol = 0xFF all channels on, 0x00 all channels off
 178          // pwmon      = 0xFF all pwms off, 0x00 pwm works with all channels
 179          //----------------------------------------------------------------------------------------
 180          // PWM01  BIT 76543210    SNK -> 01 02 03 04 05 06 07 08 09 10 11 12 13 14 | SRC -> 01 02 03 04 05 06
 181          // DC CHANNEL 21332222    J8 PIN 20 19 18 17 16 15 14 13 12 11 10  9  8  7 | J8 PIN  1  2  3  4  5  6
 182          // PWM02  BIT 543210      PWMCTRL 01 BIT  7  6  5  4  3  2  1  0  PWMCTRL 01 BIT  7  6  5  4  3  2  1  0
 183          // DC CHANNEL 21332222    SNK ->         08 07 06 05 04 03 02 01  SNK ->          X  X 14 13 12 11 10 09
 184          // PWM03  BIT 543210      PWMCTRL 03 BIT  7  6  5  4  3  2  1  0
 185          // DC CHANNEL 21332222    SRC ->               06 05 04 03 02 01
 186          //----------------------------------------------------------------------------------------
 187          #define adrsbitcontrol1       0x90   // USED TO TURN BITS ON AND OFF                      // address of di
             -screte bit control bank 1
 188          #define adrspwmon01           0xA0   // USED TO ENABLE THE PWM TO THE CONTROLLED BIT      // address of th
             -e device enable latch bank 1
 189          #define defaultpwmctrl01      0xFD   // PWM OFF EXCEPT BIT 1                              // default off s
             -tate of device enable bank = 0xFF
 190          
 191          #define adrsbitcontrol2       0x91                                                        // address of di
             -screte bit control bank 2
 192          #define adrspwmon02           0xA1                                                        // address of th
             -e device enable latch bank 2
 193          #define defaultpwmctrl02      0xFF                                                        // default off s
             -tate of device enable bank = 0x3F
 194          
 195          #define adrsbitcontrol3       0x92                                                        // address of di
             -screte bit control bank 3
