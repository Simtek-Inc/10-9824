 511          // name    : NOP                                                                          //
 512          // purpose : create a small runtime delay                                                 //
 513          // params  : the number of times to loop                                                  //
 514          // returns : void                                                                         //
 515          // notes   :                                                                              //
C51 COMPILER V8.06   MAIN                                                                  07/01/2021 16:27:13 PAGE 118 

 516          //----------------------------------------------------------------------------------------//
 517          void NOP(uint loop)                                                                       //
 518          {
 519   1            uint i;                                                                             //
 520   1      
 521   1            for (i = 0; i < loop; i++)                                                          //
 522   1             {    _nop_();    }                                                                 //
 523   1      }
