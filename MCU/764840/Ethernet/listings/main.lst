  25      =2  // I2C Register //
  26      =2  #define I2CCPR                                  0x00    // I2C Clock Pre-scale Register
  27      =2  #define I2CTR                                   0x02    // I2C Transmit Register
  28      =2  #define I2CRR                                   0x03    // I2C Receive Register
  29      =2  #define I2CCTL                                  0x04    // I2C Control Register
  30      =2  #define I2CCR                                   0x05    // I2C Command Register
  31      =2  #define I2CMSR                                  0x06    // I2C Master Status Register
  32      =2  #define I2CSDAR                                 0x08    // I2C Slave Device Address Register
  33      =2  #define I2CSSR                                  0x0A    // I2C Slave Status Register
  34      =2  // I2CCTLR //
  35      =2  #define I2C_MST_IE                              BIT0    // I2C master mode interrupt enable
  36      =2  #define I2C_ENB                                 BIT1    // I2C module enable
  37      =2  #define I2C_DISB                                0               // I2C module disable
  38      =2  #define I2C_STANDARD                    BIT2    // I2C standard speed in slave mode
  39      =2  #define I2C_FAST                                0               // I2C fast speed in slave mode
  40      =2  #define I2C_10BIT                               BIT3    // I2C 10-bit device address mode
  41      =2  #define I2C_7BIT                                0               // I2C 7-bit device address mode
  42      =2  #define I2C_RELOAD                              BIT4    // Reload I2C configuration EEPROM
  43      =2  #define I2C_SLV_IE                              BIT6    // I2C slave mode interrupt enable
  44      =2  #define I2C_MASTER_MODE                 BIT7    // I2C operated as master mode
  45      =2  #define I2C_SLAVE_MODE                  0               // I2C operated as slave mode
  46      =2  
  47      =2  // I2CCR //
  48      =2  #define I2C_RLS                                 BIT0    // release SCLK, only for slave
  49      =2  #define I2C_SLAVE_GO                    BIT1    // I2C slave go command
  50      =2  #define I2C_MASTER_GO                   BIT3    // I2C master go command
  51      =2  #define I2C_CMD_WRITE                   BIT4    // Request to send data in master mode
  52      =2  #define I2C_CMD_READ                    BIT5    // Request to receive data in master mode
  53      =2  #define I2C_STOP_COND                   BIT6    // Generate a STOP condition in master mode
  54      =2  #define I2C_NO_STOP                             0               // No STOP condition
  55      =2  #define I2C_START_COND                  BIT7    // Generate a START condition in master mode
  56      =2  
  57      =2  // I2CMSR //
  58      =2  #define I2C_INTR_FLAG                   BIT0    // Interrupt flag
  59      =2  #define I2C_TIP                                 BIT1    // Transfer in progress
  60      =2  #define I2C_RLE_ING                             BIT3    // EEPROM reloading
  61      =2  #define I2C_BL_DONE                             BIT4    // Bootloader done
  62      =2  #define I2C_ARB_LOST                    BIT5    // Arbitration lost
  63      =2  #define I2C_BUS_BUSY                    BIT6    // I2C bus busy
  64      =2  #define I2C_NO_ACK                              BIT7    // No ack after a byte transfer.
  65      =2  
  66      =2  // I2CSSR //
  67      =2  #define I2C_SLV_TXR_OK                  BIT0    // Slave transfer complete
  68      =2  #define I2C_SLV_NACK                    BIT1    // No ack condition
  69      =2  #define I2C_SLV_WR                              BIT2    // Slave write command
  70      =2  #define I2C_SLV_RD                              BIT3    // Slave read command
  71      =2  #define I2C_SLV_RESTART                 BIT4    // Restart condition detected
  72      =2  #define I2C_SLV_START                   BIT5    // Start condition detected
  73      =2  #define I2C_SLV_STOP                    BIT6    // Stop condition detected
  74      =2  #define I2C_SLV_ERR                             BIT7    // Error occur
C51 COMPILER V8.06   MAIN                                                                  07/01/2021 16:27:13 PAGE 101 

  75      =2  
  76      =2  // I2C packet direction //
  77      =2  #define I2C_MASTER                              BIT1
  78      =2  #define I2C_XMIT                                BIT0
  79      =2  #define I2C_MST_XMIT                    BIT1 + BIT0     //11 (BIT1:Master, BIT0:Xmit)
  80      =2  #define I2C_MST_RCVR                    BIT1            //10
  81      =2  #define I2C_SLV_XMIT                    BIT0            //01
  82      =2  #define I2C_SLV_RCVR                    0                       //00
  83      =2  
  84      =2  #define I2C_BUSY                                BIT0    // I2C busy flag
