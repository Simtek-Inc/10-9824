  31      =1  /* SPI register */
  32      =1  #define SPIRBR                                  0x00    // SPI Receive Buffer Register
  33      =1  #define SPITBR                                  0x04    // SPI Transmit Buffer Register
  34      =1  #define SPICTRLR                                0x08    // SPI Control Register
  35      =1  #define SPICMDR                                 0x09    // SPI Command Register
  36      =1  #define SPIBRR                                  0x0A    // SPI Baud Rate Register
  37      =1  #define SPISSR                                  0x0B    // SPI Slave Select Register
  38      =1  #define SPIISR                                  0x0C    // SPI Interrupt Status Register
  39      =1  #define SPIIER                                  0x0D    // SPI Interrupt Enable Register
  40      =1  #define SPISCR                                  0x0E    // SPI Slave Command Register
  41      =1  #define SPISB                                   0x10    // SPI Slave Buffer Register
  42      =1  
  43      =1  /* SPICTRLR */
  44      =1  #define SPI_SSP_HIGH                    BIT0    // slave select is high active
  45      =1  #define SPI_SSP_LOW                             0               // slave select is low active
  46      =1  #define SPI_CPHA_BEG                    BIT1    // spi first clock edge is issued at the beginning of transfer cycle
  47      =1  #define SPI_CPHA_HALF                   0               // spi first clock edge is issued one-half cycle of transfer cycle
  48      =1  #define SPI_CPOL_LOW                    BIT2    // clock active low
  49      =1  #define SPI_CPOL_HIGH                   0               // clock active high
  50      =1  #define SPI_LSB_FIRST                   BIT3    // the LSB is sent first
  51      =1  #define SPI_MSB_FIRST                   0               // the MSB is sent first
  52      =1  #define SPI_ENB                                 BIT4    // spi module enable
  53      =1  #define SPI_DISB                                0               // spi module disable
  54      =1  #define SPI_SS_AUTO                             BIT5    // slave select signal generated automatically
  55      =1  #define SPI_SS_NORM                             0               // slave select signal generated by SPISSR bits
  56      =1  #define SPI_MST_SEL                             BIT6    // spi master mode
  57      =1  #define SPI_SLV_SEL                             0               // spi slave mode
  58      =1  #define SPI_SSO_ENB                             BIT7    // enable driving slave select signal
  59      =1  #define SPI_SSO_DISB                    0               // put slave select signal to tri-state
  60      =1  
  61      =1  /* SPICMDR */
  62      =1  #define SPI_LOST_CLK                    BIT5    // suppress the last clock
  63      =1  #define SPI_LONG_LEN                    BIT6    // the current transfer length is small than desired length
  64      =1  #define SPI_NORMAL_LEN                  0               // the current transfer length is the desired length
  65      =1  #define SPI_GO_BSY                              BIT7    // start a transfer
  66      =1  
  67      =1  /* SPIBRR */
  68      =1  #define SLAVE_SEL_0                             ~BIT0   // slave select signal used on bit0
  69      =1  #define SLAVE_SEL_1                             ~BIT1   // slave select signal used on bit1
  70      =1  #define SLAVE_SEL_2                             ~BIT2   // slave select signal used on bit2
  71      =1  #define SLAVE_SEL_3                             ~BIT3   // slave select signal used on bit3
  72      =1  #define SLAVE_SEL_4                             ~BIT4   // slave select signal used on bit4
  73      =1  #define SLAVE_SEL_5                             ~BIT5   // slave select signal used on bit5
  74      =1  #define SLAVE_SEL_6                             ~BIT6   // slave select signal used on bit6
  75      =1  #define SLAVE_SEL_7                             ~BIT7   // slave select signal used on bit7
  76      =1  
  77      =1  /* SPIISR */
  78      =1  #define SPI_MCF                                 BIT0    // spi master mode interrupt flag
  79      =1  #define SPI_SCF                                 BIT4    // spi slave mode interrupt flag
  80      =1  
  81      =1  /* SPIIER */
  82      =1  #define SPI_STCFIE                              BIT0    // spi master mode interrupt enable
  83      =1  #define SPI_SRCFIE                              BIT4    // spi slave mode interrupt enable
  84      =1  
  85      =1  /* SPISCR */
  86      =1  #define SPI_SLV_RDY                             BIT0    // spi slave ready
