  80          /*
  81           *--------------------------------------------------------------------------------
  82           * static void spi_SlvRcvr(void)
  83           * Purpose : SPI slave receiving function in one transfer.It will get the packet
  84           *           from slave buffer register and stores into a software buffer.
  85           * Params  : None.
  86           * Returns : None.
  87           * Note    : The slave buffer register has a size of 16 bytes.
  88           *--------------------------------------------------------------------------------
  89           */
  90          #if SPI_SLAVE_ENABLE
  91          static void spi_SlvRcvr(void)
  92          {
  93   1              unsigned char   i;
  94   1              unsigned char   rxLen = 0;
  95   1              unsigned char   slvCmdType = 0;
  96   1              unsigned char   dataLen = 0;
  97   1      
  98   1              SPICIR = SPISB;
  99   1              spiSlvRxBuf[0] = SPIDR;
 100   1              slvCmdType = spiSlvRxBuf[0] & 0xF0;
 101   1              dataLen = (spiSlvRxBuf[0] & 0x0F) + 1;
 102   1              if (slvCmdType == SPI_SLV_SRSFR)
 103   1              {
 104   2                      rxLen = 1;
 105   2              }
 106   1              else if (slvCmdType == SPI_SLV_SWSFR)
 107   1              {
 108   2                      rxLen = dataLen + 1;
 109   2              }
 110   1              else if (slvCmdType == SPI_SLV_IRSFR)
 111   1              {
 112   2                      rxLen = 2;
 113   2              }
 114   1              else if (slvCmdType == SPI_SLV_IWSFR)
 115   1              {
 116   2                      rxLen = dataLen + 2;
 117   2              }
 118   1              else if (slvCmdType == SPI_SLV_BRMEM)
 119   1              {
 120   2                      rxLen = 3;
 121   2              }
 122   1              else if (slvCmdType == SPI_SLV_BWMEM)
 123   1              {
 124   2                      rxLen = dataLen + 3;
 125   2              }
 126   1              for (i = 0 ; i < rxLen ; i ++ )
 127   1              {
 128   2                      spiSlvRxBuf[1+i] = SPIDR;
 129   2              }
 130   1              /* Command abort*/
C51 COMPILER V8.06   SPI                                                                   07/01/2021 16:27:17 PAGE 20  

 131   1              SPICIR = 0xFF;
 132   1      }
