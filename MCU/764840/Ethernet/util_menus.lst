  58      =1  #define I2C_INTR_FLAG                   BIT0    // Interrupt flag
  59      =1  #define I2C_TIP                                 BIT1    // Transfer in progress
  60      =1  #define I2C_RLE_ING                             BIT3    // EEPROM reloading
  61      =1  #define I2C_BL_DONE                             BIT4    // Bootloader done
  62      =1  #define I2C_ARB_LOST                    BIT5    // Arbitration lost
  63      =1  #define I2C_BUS_BUSY                    BIT6    // I2C bus busy
  64      =1  #define I2C_NO_ACK                              BIT7    // No ack after a byte transfer.
  65      =1  
  66      =1  // I2CSSR //
