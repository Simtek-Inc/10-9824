  25      =1  // I2C Register //
  26      =1  #define I2CCPR                                  0x00    // I2C Clock Pre-scale Register
  27      =1  #define I2CTR                                   0x02    // I2C Transmit Register
  28      =1  #define I2CRR                                   0x03    // I2C Receive Register
  29      =1  #define I2CCTL                                  0x04    // I2C Control Register
  30      =1  #define I2CCR                                   0x05    // I2C Command Register
  31      =1  #define I2CMSR                                  0x06    // I2C Master Status Register
  32      =1  #define I2CSDAR                                 0x08    // I2C Slave Device Address Register
  33      =1  #define I2CSSR                                  0x0A    // I2C Slave Status Register
  34      =1  // I2CCTLR //
  35      =1  #define I2C_MST_IE                              BIT0    // I2C master mode interrupt enable
  36      =1  #define I2C_ENB                                 BIT1    // I2C module enable
  37      =1  #define I2C_DISB                                0               // I2C module disable
  38      =1  #define I2C_STANDARD                    BIT2    // I2C standard speed in slave mode
  39      =1  #define I2C_FAST                                0               // I2C fast speed in slave mode
C51 COMPILER V8.06   UTIL_MENUS                                                            03/13/2026 10:21:45 PAGE 22  

  40      =1  #define I2C_10BIT                               BIT3    // I2C 10-bit device address mode
  41      =1  #define I2C_7BIT                                0               // I2C 7-bit device address mode
  42      =1  #define I2C_RELOAD                              BIT4    // Reload I2C configuration EEPROM
  43      =1  #define I2C_SLV_IE                              BIT6    // I2C slave mode interrupt enable
  44      =1  #define I2C_MASTER_MODE                 BIT7    // I2C operated as master mode
  45      =1  #define I2C_SLAVE_MODE                  0               // I2C operated as slave mode
  46      =1  
  47      =1  // I2CCR //
  48      =1  #define I2C_RLS                                 BIT0    // release SCLK, only for slave
  49      =1  #define I2C_SLAVE_GO                    BIT1    // I2C slave go command
  50      =1  #define I2C_MASTER_GO                   BIT3    // I2C master go command
  51      =1  #define I2C_CMD_WRITE                   BIT4    // Request to send data in master mode
  52      =1  #define I2C_CMD_READ                    BIT5    // Request to receive data in master mode
  53      =1  #define I2C_STOP_COND                   BIT6    // Generate a STOP condition in master mode
  54      =1  #define I2C_NO_STOP                             0               // No STOP condition
  55      =1  #define I2C_START_COND                  BIT7    // Generate a START condition in master mode
  56      =1  
