1271          //----------------------------------------------------------------------------------------
1272          // name      : UTIL_StrCmp(char//Str1, char *Str2)
1273          // purpose   : Special string compare routine. returns 0 if strings match, 
1274          //             else returns char where 1st character mismatch occured. ie:
1275          //             stcmp("help", "helper") returns a 5. stcmp("help", "nohelp") 
1276          //             returns a 1. Also: treats space as end of string.
1277          // params    : char *Str1, char *Str2
1278          // returns   : 0 if strings match, else returns char where 1st mismatch occured.
1279          // note      :
1280          //----------------------------------------------------------------------------------------
1281          int          UTIL_StrCmp(char *Str1, char *Str2)
1282          {
1283   1            int   Posi = 1;                                                                     // byte being ch
             -ecked //
1284   1      
1285   1            while (*Str1 && *Str1 != ' ')                                                       // keep going un
             -til the character is a null, or a space
1286   1              {
1287   2              if ((*Str1 ++) != (*Str2 ++))                                                     // check chars f
             -or match, increment both char pointers if they match
1288   2                {     return (Posi);      }                                                     // character mis
             -match found, return failed condiition/position
1289   2              Posi ++;                                                                          // move position
             - indicator to next character
1290   2              }
1291   1            if (*Str2)                                                                          // check to make
             - sure there are no more characters in string 2
1292   1              {       return(Posi);       }                                                     // s2 was longer
             - than s1 return fail condition
1293   1            return(0);                                                                          // return pass c
             -ondition
1294   1      }
