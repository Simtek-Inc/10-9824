1249   1            Len = UTIL_StrLen(ConStart);                                            // calculate the length of t
             -he string
1250   1            if (Len > (sizeof(ulong) * 2))                                          // check that the number of 
             -characters does not exceed the number of digit in an unsigned long
1251   1              {       return (FALSE); }                                             // the length is greater, re
             -turn an error
1252   1      
1253   1            // converting //
1254   1            *ConRes = 0;                                                            // set the return value to z
             -ero
1255   1            for (ShiftIdx = 0; Len != 0; ShiftIdx ++, Len --)                       // convert each character in
             - the string from ASCII to a number, starting with the right most character
1256   1              {
1257   2              TmpRes = *(ConStart + Len - 1);                                       // get the character
1258   2              if ((TmpRes >= '0') && (TmpRes <= '9'))                               // check if the character is
             - a decimal digit
1259   2                TmpRes -= '0';                                                      // it was, convert for ASCII
             - to decimal
1260   2              else if ((TmpRes >= 'a') && (TmpRes <= 'f'))                          // check if the character is
             - a hexadecimal digit in lower case
