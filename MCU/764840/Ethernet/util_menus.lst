           =2 // I2C Register //
           =2 #define I2CCPR                                  0x00    // I2C Clock Pre-scale Register
           =2 #define I2CTR                                   0x02    // I2C Transmit Register
           =2 #define I2CRR                                   0x03    // I2C Receive Register
           =2 #define I2CCTL                                  0x04    // I2C Control Register
           =2 #define I2CCR                                   0x05    // I2C Command Register
           =2 #define I2CMSR                                  0x06    // I2C Master Status Register
           =2 #define I2CSDAR                                 0x08    // I2C Slave Device Address Register
           =2 #define I2CSSR                                  0x0A    // I2C Slave Status Register
           =2 // I2CCTLR //
           =2 #define I2C_MST_IE                              BIT0    // I2C master mode interrupt enable
           =2 #define I2C_ENB                                 BIT1    // I2C module enable
           =2 #define I2C_DISB                                0               // I2C module disable
           =2 #define I2C_STANDARD                    BIT2    // I2C standard speed in slave mode
           =2 #define I2C_FAST                                0               // I2C fast speed in slave mode
           =2 #define I2C_10BIT                               BIT3    // I2C 10-bit device address mode
           =2 #define I2C_7BIT                                0               // I2C 7-bit device address mode
           =2 #define I2C_RELOAD                              BIT4    // Reload I2C configuration EEPROM
           =2 #define I2C_SLV_IE                              BIT6    // I2C slave mode interrupt enable
           =2 #define I2C_MASTER_MODE                 BIT7    // I2C operated as master mode
           =2 #define I2C_SLAVE_MODE                  0               // I2C operated as slave mode
           =2 
           =2 // I2CCR //
           =2 #define I2C_RLS                                 BIT0    // release SCLK, only for slave
           =2 #define I2C_SLAVE_GO                    BIT1    // I2C slave go command
           =2 #define I2C_MASTER_GO                   BIT3    // I2C master go command
           =2 #define I2C_CMD_WRITE                   BIT4    // Request to send data in master mode
           =2 #define I2C_CMD_READ                    BIT5    // Request to receive data in master mode
           =2 #define I2C_STOP_COND                   BIT6    // Generate a STOP condition in master mode
           =2 #define I2C_NO_STOP                             0               // No STOP condition
           =2 #define I2C_START_COND                  BIT7    // Generate a START condition in master mode
           =2 
           =2 // I2CMSR //
           =2 #define I2C_INTR_FLAG                   BIT0    // Interrupt flag
           =2 #define I2C_TIP                                 BIT1    // Transfer in progress
           =2 #define I2C_RLE_ING                             BIT3    // EEPROM reloading
           =2 #define I2C_BL_DONE                             BIT4    // Bootloader done
           =2 #define I2C_ARB_LOST                    BIT5    // Arbitration lost
           =2 #define I2C_BUS_BUSY                    BIT6    // I2C bus busy
           =2 #define I2C_NO_ACK                              BIT7    // No ack after a byte transfer.
           =2 
           =2 // I2CSSR //
           =2 #define I2C_SLV_TXR_OK                  BIT0    // Slave transfer complete
           =2 #define I2C_SLV_NACK                    BIT1    // No ack condition
           =2 #define I2C_SLV_WR                              BIT2    // Slave write command
           =2 #define I2C_SLV_RD                              BIT3    // Slave read command
           =2 #define I2C_SLV_RESTART                 BIT4    // Restart condition detected
           =2 #define I2C_SLV_START                   BIT5    // Start condition detected
           =2 #define I2C_SLV_STOP                    BIT6    // Stop condition detected
           =2 #define I2C_SLV_ERR                             BIT7    // Error occur
           =2 
           =2 // I2C packet direction //
           =2 #define I2C_MASTER                              BIT1
           =2 #define I2C_XMIT                                BIT0
           =2 #define I2C_MST_XMIT                    BIT1 + BIT0     //11 (BIT1:Master, BIT0:Xmit)
           =2 #define I2C_MST_RCVR                    BIT1            //10
           =2 #define I2C_SLV_XMIT                    BIT0            //01
           =2 #define I2C_SLV_RCVR                    0                       //00
           =2 
           =2 #define I2C_BUSY                                BIT0    // I2C busy flag
           =2 #define I2C_RESTART                             BIT1    // I2C restart flag
           =2 #define I2C_LOST                                NIT2    // I2C arbitration lost flag
C51 COMPILER V8.06   UTIL_MENUS                                                            03/13/2026 10:21:45 PAGE 36  

           =2 #define I2C_NACK                                BIT7    // I2C NACK flag
           =2 
           =2 // I2C Slave Command //
           =2 #define I2C_SLV_SRSFR                   BIT5                    // SFR single read
           =2 #define I2C_SLV_SWSFR                   BIT7+BIT5               // SFR single write
           =2 #define I2C_SLV_IRSFR                   BIT5+BIT4               // SFR indirect read
           =2 #define I2C_SLV_IWSFR                   BIT7+BIT5+BIT4  // SFR indirect write
           =2 #define I2C_SLV_BRDM                    BIT6                    // Memory burst read
           =2 #define I2C_SLV_BWDM                    BIT7+BIT6               // Memory burst write
           =2 
           =2 // I2C Master Clock //
           =2 #define I2C_FAST_25M                    0x0C    // Fast mode pre-scale at 25M
           =2 #define I2C_FAST_50M                    0x18    // Fast mode pre-scale at 50M
           =2 #define I2C_FAST_100M                   0x31    // Fast mode pre-scale at 100M
           =2 #define I2C_STD_25M                             0x3A    // Standard mode pre-scale at 25M
           =2 #define I2C_STD_50M                             0x76    // Standard mode pre-scale at 50M
           =2 #define I2C_STD_100M                    0xC7    // Standard mode pre-scale at 100M
           =2 
