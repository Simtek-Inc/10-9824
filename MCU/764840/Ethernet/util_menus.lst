 448          //----------------------------------------------------------------------------------------
 449          static void UTIL_ReadI2C(void *cmdLine)
 450          {
 451   1            byte *cmd    = NULL;
 452   1            ulong device = 0;
 453   1            ulong addr   = 0;
 454   1            ulong len    = 0;
 455   1            ulong i;
 456   1            char  memdata[256];
 457   1        
 458   1            cmd = UTIL_NextArg(cmdLine);
 459   1            if (*cmd == 0)
 460   1              {
 461   2              printd("Usage : read <device address> <memory address> <memory length>\n\r");
 462   2              return;
 463   2              }
 464   1            if (UTIL_StrToULong(cmd, &device) == FALSE)
 465   1              {
 466   2              printd("Device address error.\n\r");
 467   2              return;
 468   2              }
 469   1            CHECK_RANGE(device, 0, 0x07, "The device address is out of range.\n\r");
 470   1            cmd = UTIL_NextArg(cmd);
 471   1            if (*cmd == 0)
 472   1              {
 473   2              printd("No memory address specified\n\r");
 474   2              printd("Usage : read <device address> <memory address> <memory length>\n\r");
 475   2              return;
 476   2              }
 477   1            if (UTIL_StrToULong(cmd, &addr) == FALSE)
 478   1              {
 479   2              printd("Memory address error.\n\r");
 480   2              return;
 481   2              }
 482   1            CHECK_RANGE(addr, 0, 0x07FF, "The memory address is out of range.\n\r");
 483   1            cmd = UTIL_NextArg(cmd);
 484   1            if (*cmd == 0)
 485   1              {
 486   2              printd("No read length specified\n\r");
 487   2              printd("Usage : read <device address> <memory address> <memory length>\n\r");
 488   2              return;
C51 COMPILER V8.06   UTIL_MENUS                                                            03/13/2026 10:21:45 PAGE 58  

 489   2              }
 490   1            if (UTIL_StrToULong(cmd, &len) == FALSE)
 491   1              {
 492   2              printd("Memory length error.\n\r");
 493   2              printd("length = %lu\n\r",len);
 494   2              return;
 495   2              }
 496   1            CHECK_RANGE(len, 1, 0x07FF, "The length is out of range.\n\r");
 497   1            if((len / 16) > 0)
 498   1              { 
 499   2              printd(" Address    00 01 02 03 04 05 06 07 08 09 0A 0B 0C 0D 0E 0F\n\r");
 500   2              printd("         |--------------------------------------------------\n\r");
 501   2              }
 502   1            else
 503   1              {
 504   2              printd(" Address    ");
 505   2              for(i = 0; i < len;i++)
 506   2                printd("%02bx ",(byte)i);
 507   2              printd("\n\r");  
 508   2              printd("         |--");
 509   2              for(i = 0; i < len;i++)
 510   2                printd("---");
 511   2              printd("\n\r");  
 512   2              }
 513   1            if (EEPROM_Read((byte)(device|0xA0), (byte)addr, &memdata, (uint)len) == I2C_OK)
 514   1              {
 515   2              for (i = 0 ; i < len ; i ++)
 516   2                {
 517   3                if (((i) % 16) == 0)                    printd(" 0x%04dx  |  ",(uint)(addr+i)); // display the a
             -ddress in from of the begining of the line, and then every 16th
 518   3                printd("%02bx ", (byte)(memdata[i]));                                          // display the co
             -ntents of the memory cell
 519   3                if (((i+1) % 16) == 0)                  printd("\n\r");                         // wrap around a
             -fter 16th cell
 520   3                }
 521   2              printd("\n\r");
 522   2              }
 523   1            else
 524   1              {        printd("Read Error.\n");        }
 525   1      } // End of UTIL_ReadI2C () //
