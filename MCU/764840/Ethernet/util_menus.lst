1264   2              else                                                                  // the character was not a h
             -exadecimal digit
1265   2                return (FALSE);                                                     // the conversion failed, re
             -port to calling routine
1266   2              *ConRes |= (TmpRes << (ShiftIdx * 4));                                // add the number to the val
             -ue, in the current digit location
1267   2              }
1268   1            return (TRUE);                                                          // the conversion completed 
             -successfully, report to calling routine
1269   1      }
