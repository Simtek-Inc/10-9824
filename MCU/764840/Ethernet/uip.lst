           =2   } icmp;                 //< ICMP statistics. //
           =2   struct {
           =2     uip_stats_t drop;     //< Number of dropped TCP segments. //
           =2     uip_stats_t recv;     //< Number of recived TCP segments. //
           =2     uip_stats_t sent;     //< Number of sent TCP segments. //
           =2     uip_stats_t chkerr;   //< Number of TCP segments with a bad checksum. //
           =2     uip_stats_t ackerr;   //< Number of TCP segments with a bad ACK number. //
           =2     uip_stats_t rst;      //< Number of recevied TCP RST (reset) segments. //
           =2     uip_stats_t rexmit;   //< Number of retransmitted TCP segments. //
           =2     uip_stats_t syndrop;  //< Number of dropped SYNs due to too few connections was avaliable. //
           =2     uip_stats_t synrst;   //< Number of SYNs for closed ports, triggering a RST. //
           =2   } tcp;                  //< TCP statistics. //
           =2 };
