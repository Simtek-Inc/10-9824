           =2 //
           =2 // Representation of a uIP TCP connection.
           =2 //
           =2 // The uip_conn structure is used for identifying a connection. All
           =2 // but one field in the structure are to be considered read-only by an
           =2 // application. The only exception is the appstate field whos purpose
           =2 // is to let the application store application-specific state (e.g.,
           =2 // file pointers) for the connection. The size of this field is
           =2 // configured in the "uipopt.h" header file.
           =2 //
           =2 struct uip_conn {
           =2         uint ripaddr[2];    //< The IP address of the remote host. //
           =2 
           =2         uint lport;         //< The local TCP port, in network byte order. //
           =2         uint rport;         //< The local remote TCP port, in network byte order. //  
           =2 
           =2         byte rcv_nxt[4];    //< The sequence number that we expect to receive next. //
           =2         byte snd_nxt[4];    //< The sequence number that was last sent by us. //
           =2         uint len;           //< Length of the data that was previously sent. //
           =2         uint mss;           //< Current maximum segment size for the connection. //
           =2         uint initialmss;    //< Initial maximum segment size for the connection. //  
           =2         byte sa;            //< Retransmission time-out calculation state variable. //
           =2         byte sv;            //< Retransmission time-out calculation state variable. //
           =2         byte rto;           //< Retransmission time-out. //
           =2         byte tcpstateflags; //< TCP state and flags. //
           =2         byte timer;         //< The retransmission timer. //
           =2         byte nrtx;          //< The number of retransmissions for the last segment sent. //
           =2 
           =2         byte window[2];
           =2         byte keepaliveflag;
           =2     byte sndkeepalive; // number of keepalive packet was sent //
           =2         uint keepalivetick;
           =2         byte tcpip_id;
           =2 
           =2         // The application state. //
           =2 //      byte appstate[UIP_APPSTATE_SIZE];  
           =2 };
