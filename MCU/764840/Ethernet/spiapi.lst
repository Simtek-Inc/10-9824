  45          /*
  46           *--------------------------------------------------------------------------------
  47           * bool SPI_WriteEnable(void)
  48           * Purpose : Enable a write process before sending a packet to write.
  49           * Params  : none
  50           * Returns : TRUE - successful
  51           * Note    : Write Enable must be initial when executing all write function.
  52           *--------------------------------------------------------------------------------
  53           */
  54          bool SPI_WriteEnable(void)
  55          {
  56   1              unsigned char   xmitByte = 0;
  57   1      //    printd("got into writeEnable\n\r");                                         
  58   1              xmitByte = SPI_WREN;               
  59   1              SPI_FlagEnb(SPI_BUSY);
  60   1              SPI_MstXmit(&xmitByte, 8, SPI_NORMAL_LEN|SPI_GO_BSY);
  61   1      
  62   1              while (SPI_FlagChk(SPI_BUSY)) {
  63   2              SPI_Func();
  64   2      //        printd("exit spi_func\n\r");
  65   2          }                 //Stuck in this loop...
  66   1      
  67   1              return TRUE;
  68   1      }
  69          
  70          /*
  71           *--------------------------------------------------------------------------------
  72           * bool SPI_WriteDisable(void)
  73           * Purpose : Disable a write process.
  74           * Params  : none
  75           * Returns : TRUE - successful
  76           * Note    : After WriteDisable executed, all writing function will be fail.
  77           *--------------------------------------------------------------------------------
  78           */
  79          bool SPI_WriteDisable(void)
  80          {
  81   1              unsigned char   xmitByte = 0;
  82   1              
  83   1              xmitByte = SPI_WRDI;
  84   1              SPI_FlagEnb(SPI_BUSY);
  85   1              SPI_MstXmit(&xmitByte, 8, SPI_NORMAL_LEN|SPI_GO_BSY);
  86   1      
C51 COMPILER V8.06   SPIAPI                                                                03/13/2026 10:21:46 PAGE 18  

  87   1              while (SPI_FlagChk(SPI_BUSY)) {}
  88   1      
  89   1              return TRUE;
  90   1      }
