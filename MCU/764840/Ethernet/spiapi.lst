 248          bool SPI_ByteRead(unsigned short addrOfMem, unsigned char *ptByteData)
 249          {
 250   1              unsigned char   byteRead[4];
 251   1              unsigned char   status = 0;
 252   1              
 253   1              byteRead[3] = SPI_READ;
 254   1              byteRead[2] = (unsigned char)(addrOfMem >> 8);
 255   1              byteRead[1] = (unsigned char)(addrOfMem);
 256   1              byteRead[0] = *ptByteData;
