 175   1              SPI_FlagEnb(SPI_BUSY);
 176   1              SPI_MstXmit(&byteWrite, 32, SPI_NORMAL_LEN|SPI_GO_BSY);
 177   1              while (SPI_FlagChk(SPI_BUSY)) {}
 178   1              
 179   1              return TRUE;
 180   1      }
