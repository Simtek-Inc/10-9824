  92          /*
  93           *--------------------------------------------------------------------------------
  94           * bool SPI_WriteStatus(unsigned char status)
  95           * Purpose : Change a device status register.
  96           * Params  : status - changed value.
  97           * Returns : TRUE - successful.
  98           * Note    :
  99           *--------------------------------------------------------------------------------
 100           */
 101          bool SPI_WriteStatus(unsigned char status)
 102          {
 103   1              unsigned char   writeStatus[2];
 104   1              
 105   1              writeStatus[1] = SPI_WRSR;
 106   1              writeStatus[0] = status;
 107   1      
 108   1              if (!SPI_WriteEnable())
 109   1                      return FALSE;
 110   1              SPI_FlagEnb(SPI_BUSY);
 111   1              SPI_MstXmit(&writeStatus, 16, SPI_NORMAL_LEN|SPI_GO_BSY);
 112   1              while (SPI_FlagChk(SPI_BUSY)) {}
 113   1              
 114   1              return TRUE;
 115   1      }
 116          
 117          /*
 118           *--------------------------------------------------------------------------------
 119           * bool SPI_ReadStatus(unsigned char *status)
 120           * Purpose : Read a device status register.
 121           * Params  : *status - a pointer of status value.
 122           * Returns : TRUE - successful
 123           * Note    : 
 124           *--------------------------------------------------------------------------------
 125           */
 126          bool SPI_ReadStatus(unsigned char *status)
 127          {
 128   1              unsigned char   readStatus[2];
 129   1              
 130   1              readStatus[1] = SPI_RDSR;
 131   1              readStatus[0] = 0;
 132   1      //    printd("read status\n\r");
 133   1              
 134   1              SPI_FlagEnb(SPI_BUSY);
 135   1              SPI_MstXmit(&readStatus, 16, SPI_NORMAL_LEN|SPI_GO_BSY);
 136   1      //    printd("transmit\n\r");
 137   1      
 138   1              while (SPI_FlagChk(SPI_BUSY)) {SPI_Func();}
 139   1      //    printd("busy\n\r");
 140   1              SPI_GetData(&readStatus);
 141   1      //    printd("got data\n\r");
 142   1              *status = readStatus[0];
 143   1      //    printd("end of read status\n\r");
 144   1              return TRUE;
 145   1      }
