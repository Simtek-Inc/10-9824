 851      =2      uip_stats_t recv;     //< Number of recived TCP segments. //
 852      =2      uip_stats_t sent;     //< Number of sent TCP segments. //
 853      =2      uip_stats_t chkerr;   //< Number of TCP segments with a bad checksum. //
 854      =2      uip_stats_t ackerr;   //< Number of TCP segments with a bad ACK number. //
 855      =2      uip_stats_t rst;      //< Number of recevied TCP RST (reset) segments. //
 856      =2      uip_stats_t rexmit;   //< Number of retransmitted TCP segments. //
 857      =2      uip_stats_t syndrop;  //< Number of dropped SYNs due to too few connections was avaliable. //
 858      =2      uip_stats_t synrst;   //< Number of SYNs for closed ports, triggering a RST. //
 859      =2    } tcp;                  //< TCP statistics. //
 860      =2  };
