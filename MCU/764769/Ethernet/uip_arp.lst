  94      =1  
  95      =1  // The uip_arp_ipin() function should be called whenever an IP packet
  96      =1  // arrives from the Ethernet. This function refreshes the ARP table or
  97      =1  // inserts a new mapping if none exists. The function assumes that an
  98      =1  // IP packet with an Ethernet header is present in the uip_buf buffer
  99      =1  // and that the length of the packet is in the uip_len variable.
 100      =1  //void uip_arp_ipin(void);
 101      =1  
 102      =1  // The uip_arp_arpin() should be called when an ARP packet is received
 103      =1  // by the Ethernet driver. This function also assumes that the
 104      =1  // Ethernet frame is present in the uip_buf buffer. When the
 105      =1  // uip_arp_arpin() function returns, the contents of the uip_buf
 106      =1  // buffer should be sent out on the Ethernet if the uip_len variable
 107      =1  // is > 0.
 108      =1  //void uip_arp_arpin(void);
 109      =1  
 110      =1  // The uip_arp_out() function should be called when an IP packet
 111      =1  // should be sent out on the Ethernet. This function creates an
 112      =1  // Ethernet header before the IP header in the uip_buf buffer. The
 113      =1  // Ethernet header will have the correct Ethernet MAC destination
 114      =1  // address filled in if an ARP table entry for the destination IP
 115      =1  // address (or the IP address of the default router) is present. If no
 116      =1  // such table entry is found, the IP packet is overwritten with an ARP
 117      =1  // request and we rely on TCP to retransmit the packet that was
 118      =1  // overwritten. In any case, the uip_len variable holds the length of
 119      =1  // the Ethernet frame that should be transmitted.
 120      =1  //void uip_arp_out(void);
 121      =1  
 122      =1  // The uip_arp_timer() function should be called every ten seconds. It
 123      =1  // is responsible for flushing old entries in the ARP table.
 124      =1  void uip_arp_timer(void);
