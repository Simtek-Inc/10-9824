 417      =3   */
 418      =3  
 419      =3  /**
 420      =3   * The size of the uIP packet buffer.
 421      =3   *
 422      =3   * The uIP packet buffer should not be smaller than 60 bytes, and does
 423      =3   * not need to be larger than 1500 bytes. Lower size results in lower
 424      =3   * TCP throughput, larger size results in higher TCP throughput.
 425      =3   *
 426      =3   * \hideinitializer
 427      =3   */
 428      =3  #define UIP_BUFSIZE     1514
 429      =3  
 430      =3  
 431      =3  /**
 432      =3   * Determines if statistics support should be compiled in.
 433      =3   *
 434      =3   * The statistics is useful for debugging and to show the user.
 435      =3   *
 436      =3   * \hideinitializer
C51 COMPILER V8.06   UIP_ARP                                                               03/17/2026 10:18:44 PAGE 17  

 437      =3   */
 438      =3  #define UIP_STATISTICS  0
 439      =3  
 440      =3  /**
 441      =3   * Determines if logging of certain events should be compiled in.
 442      =3   *
 443      =3   * This is useful mostly for debugging. The function uip_log()
 444      =3   * must be implemented to suit the architecture of the project, if
 445      =3   * logging is turned on.
 446      =3   *
 447      =3   * \hideinitializer
 448      =3   */
 449      =3  #define UIP_LOGGING     0
 450      =3  
 451      =3  /**
 452      =3   * Print out a uIP log message.
 453      =3   *
 454      =3   * This function must be implemented by the module that uses uIP, and
 455      =3   * is called by uIP whenever a log message is generated.
 456      =3   */
 457      =3  void uip_log(char *msg);
 458      =3  
 459      =3  /**
 460      =3   * The link level header length.
 461      =3   *
 462      =3   * This is the offset into the uip_buf where the IP header can be
 463      =3   * found. For Ethernet, this should be set to 14. For SLIP, this
 464      =3   * should be set to 0.
 465      =3   *
 466      =3   * \hideinitializer
 467      =3   */
 468      =3  #define UIP_LLH_LEN     14
 469      =3  
 470      =3  /** @} */
 471      =3  /*------------------------------------------------------------------------------*/
 472      =3  /**
 473      =3   * \defgroup uipoptcpu CPU architecture configuration
 474      =3   * @{
 475      =3   *
 476      =3   * The CPU architecture configuration is where the endianess of the
 477      =3   * CPU on which uIP is to be run is specified. Most CPUs today are
 478      =3   * little endian, and the most notable exception are the Motorolas
 479      =3   * which are big endian. The BYTE_ORDER macro should be changed to
 480      =3   * reflect the CPU architecture on which uIP is to be run.
 481      =3   */
 482      =3  #ifndef LITTLE_ENDIAN
 483      =3  #define LITTLE_ENDIAN  3412
 484      =3  #endif /* LITTLE_ENDIAN */
 485      =3  #ifndef BIG_ENDIAN
 486      =3  #define BIG_ENDIAN     1234
 487      =3  #endif /* BIGE_ENDIAN */
 488      =3  
 489      =3  /**
 490      =3   * The byte order of the CPU architecture on which uIP is to be run.
 491      =3   *
 492      =3   * This option can be either BIG_ENDIAN (Motorola byte order) or
 493      =3   * LITTLE_ENDIAN (Intel byte order).
 494      =3   *
 495      =3   * \hideinitializer
 496      =3   */
 497      =3  #ifndef BYTE_ORDER
 498      =3  #define BYTE_ORDER     BIG_ENDIAN     // Keil C
C51 COMPILER V8.06   UIP_ARP                                                               03/17/2026 10:18:44 PAGE 18  

 499      =3  #endif /* BYTE_ORDER */
 500      =3  
 501      =3  /** @} */
 502      =3  /*------------------------------------------------------------------------------*/
 503      =3  
 504      =3  /**
 505      =3   * \defgroup uipoptapp Appication specific configurations
 506      =3   * @{
 507      =3   *
 508      =3   * An uIP application is implemented using a single application
 509      =3   * function that is called by uIP whenever a TCP/IP event occurs. The
 510      =3   * name of this function must be registered with uIP at compile time
 511      =3   * using the UIP_APPCALL definition.
 512      =3   *
 513      =3   * uIP applications can store the application state within the
 514      =3   * uip_conn structure by specifying the size of the application
 515      =3   * structure with the UIP_APPSTATE_SIZE macro.
 516      =3   *
 517      =3   * The file containing the definitions must be included in the
 518      =3   * uipopt.h file.
 519      =3   *
 520      =3   * The following example illustrates how this can look.
 521      =3   \code
 522      =3  
 523      =3  void httpd_appcall(void);
 524      =3  #define UIP_APPCALL     httpd_appcall
 525      =3  
 526      =3  struct httpd_state {
 527      =3    uint state; 
 528      =3    uint count;
 529      =3    char *dataptr;
 530      =3    char *script;
 531      =3  };
 532      =3  #define UIP_APPSTATE_SIZE (sizeof(struct httpd_state))
 533      =3   \endcode
 534      =3   */
 535      =3  
 536      =3  /**
 537      =3   * \var #define UIP_APPCALL
 538      =3   *
 539      =3   * The name of the application function that uIP should call in
 540      =3   * response to TCP/IP events.
 541      =3   *
 542      =3   */
 543      =3  
 544      =3  /**
 545      =3   * \var #define UIP_APPSTATE_SIZE
 546      =3   *
 547      =3   * The size of the application state that is to be stored in the
 548      =3   * uip_conn structure.
 549      =3   */
 550      =3  /** @} */
 551      =3  
 552      =3  /* Include the header file for the application program that should be
 553      =3     used. If you don't use the example web server, you should change
 554      =3     this. */
 555      =3  
 556      =3  
 557      =3  #endif /* __UIPOPT_H__ */
  59      =2  
  60      =2  //-----------------------------------------------------------------------------------//
  61      =2  // First, the functions that should be called from the
C51 COMPILER V8.06   UIP_ARP                                                               03/17/2026 10:18:44 PAGE 19  

  62      =2  // system. Initialization, the periodic timer and incoming packets are
  63      =2  // handled by the following three functions.
  64      =2  //
  65      =2  
  66      =2  //
  67      =2  // \defgroup uipconffunc uIP configuration functions
  68      =2  // @{
  69      =2  //
  70      =2  // The uIP configuration functions are used for setting run-time
  71      =2  // parameters in uIP such as IP addresses. 
  72      =2  //
  73      =2  
  74      =2  //
  75      =2  // Set the IP address of this host.
  76      =2  //
  77      =2  // The IP address is represented as a 4-byte array where the first
  78      =2  // octet of the IP address is put in the first member of the 4-byte
  79      =2  // array.
  80      =2  //
  81      =2  // \param addr A pointer to a 4-byte representation of the IP address.
  82      =2  //
  83      =2  // \hideinitializer
  84      =2  //
  85      =2  #define uip_sethostaddr(addr) do { uip_hostaddr[0] = addr[0]; \
  86      =2                                uip_hostaddr[1] = addr[1]; } while(0)
  87      =2  
  88      =2  //
  89      =2  // Get the IP address of this host.
  90      =2  //
  91      =2  // The IP address is represented as a 4-byte array where the first
  92      =2  // octet of the IP address is put in the first member of the 4-byte
  93      =2  // array.
  94      =2  //
  95      =2  // \param addr A pointer to a 4-byte array that will be filled in with
  96      =2  // the currently configured IP address.
  97      =2  //
  98      =2  // \hideinitializer
  99      =2  //
 100      =2  #define uip_gethostaddr(addr) do { addr[0] = uip_hostaddr[0]; \
 101      =2                                addr[1] = uip_hostaddr[1]; } while(0)
 102      =2  
 103      =2  //
 104      =2  // \defgroup uipinit uIP initialization functions
 105      =2  // @{
 106      =2  //
 107      =2  // The uIP initialization functions are used for booting uIP.
 108      =2  //
 109      =2  
 110      =2  //
 111      =2  // uIP initialization function.
 112      =2  //
 113      =2  // This function should be called at boot up to initilize the uIP
 114      =2  // TCP/IP stack.
 115      =2  //
 116      =2  void uip_init(void);
 117      =2  
 118      =2  // @} //
 119      =2  
 120      =2  // \defgroup uipdevfunc uIP device driver functions
 121      =2  // @{
 122      =2  //
 123      =2  // These functions are used by a network device driver for interacting
C51 COMPILER V8.06   UIP_ARP                                                               03/17/2026 10:18:44 PAGE 20  

 124      =2  // with uIP.
 125      =2  //
 126      =2  // Process an incoming packet.
 127      =2  //
 128      =2  // This function should be called when the device driver has received
 129      =2  // a packet from the network. The packet from the device driver must
 130      =2  // be present in the uip_buf buffer, and the length of the packet
 131      =2  // should be placed in the uip_len variable.
 132      =2  //
 133      =2  // When the function returns, there may be an outbound packet placed
 134      =2  // in the uip_buf packet buffer. If so, the uip_len variable is set to
 135      =2  // the length of the packet. If no packet is to be sent out, the
 136      =2  // uip_len variable is set to 0.
 137      =2  //
 138      =2  // The usual way of calling the function is presented by the source
 139      =2  // code below.
 140      =2  // \code
 141      =2  //  uip_len = devicedriver_poll();
 142      =2  //  if(uip_len > 0) {
 143      =2  //    uip_input();
 144      =2  //    if(uip_len > 0) {
 145      =2  //      devicedriver_send();
 146      =2  //    }
 147      =2  //  }
 148      =2  // \endcode
 149      =2  //
 150      =2  // \note If you are writing a uIP device driver that needs ARP
 151      =2  // (Address Resolution Protocol), e.g., when running uIP over
 152      =2  // Ethernet, you will need to call the uIP ARP code before calling
 153      =2  // this function:
 154      =2  // \code
 155      =2  //  #define BUF ((struct uip_eth_hdr *)&uip_buf[0])
 156      =2  //  uip_len = ethernet_devicedrver_poll();
 157      =2  //  if(uip_len > 0) {
 158      =2  //    if(BUF->type == HTONS(UIP_ETHTYPE_IP)) {
 159      =2  //      uip_arp_ipin();
 160      =2  //      uip_input();
 161      =2  //      if(uip_len > 0) {
 162      =2  //        uip_arp_out();
 163      =2  //      ethernet_devicedriver_send();
 164      =2  //      }
 165      =2  //    } else if(BUF->type == HTONS(UIP_ETHTYPE_ARP)) {
 166      =2  //      uip_arp_arpin();
 167      =2  //      if(uip_len > 0) {
 168      =2  //      ethernet_devicedriver_send();
 169      =2  //      }
 170      =2  //    }
 171      =2  // \endcode
 172      =2  //
 173      =2  // \hideinitializer
 174      =2  //
 175      =2  //#define uip_input()        uip_process(UIP_DATA)
 176      =2  
 177      =2  //
 178      =2  // Periodic processing for a connection identified by its number.
 179      =2  // 
 180      =2  // This function does the necessary periodic processing (timers,
 181      =2  // polling) for a uIP TCP conneciton, and should be called when the
 182      =2  // periodic uIP timer goes off. It should be called for every
 183      =2  // connection, regardless of whether they are open of closed.
 184      =2  //
 185      =2  // When the function returns, it may have an outbound packet waiting
C51 COMPILER V8.06   UIP_ARP                                                               03/17/2026 10:18:44 PAGE 21  

 186      =2  // for service in the uIP packet buffer, and if so the uip_len
 187      =2  // variable is set to a value larger than zero. The device driver
 188      =2  // should be called to send out the packet.
 189      =2  //
 190      =2  // The ususal way of calling the function is through a for() loop like
 191      =2  // this:
 192      =2  // \code
 193      =2  //  for(i = 0; i < UIP_CONNS; ++i) {
 194      =2  //    uip_periodic(i);
 195      =2  //    if(uip_len > 0) {
 196      =2  //      devicedriver_send();
 197      =2  //    }
 198      =2  //  }
 199      =2  // \endcode
 200      =2  //
 201      =2  // \note If you are writing a uIP device driver that needs ARP
 202      =2  // (Address Resolution Protocol), e.g., when running uIP over
 203      =2  // Ethernet, you will need to call the uip_arp_out() function before
 204      =2  // calling the device driver:
 205      =2  // \code
 206      =2  //  for(i = 0; i < UIP_CONNS; ++i) {
 207      =2  //    uip_periodic(i);
 208      =2  //    if(uip_len > 0) {
 209      =2  //      uip_arp_out();
 210      =2  //      ethernet_devicedriver_send();
 211      =2  //    }
 212      =2  //  }
 213      =2  // \endcode 
 214      =2  //
 215      =2  // \param conn The number of the connection which is to be periodically polled.
 216      =2  //
 217      =2  // \hideinitializer
 218      =2  //
 219      =2  #define uip_periodic(conn) do { uip_conn = &uip_conns[conn]; \
 220      =2                                  uip_process(UIP_TIMER); } while (0)
 221      =2  
 222      =2  //
 223      =2  // Periodic processing for a connection identified by a pointer to its structure.
 224      =2  //
 225      =2  // Same as uip_periodic() but takes a pointer to the actual uip_conn
 226      =2  // struct instead of an integer as its argument. This function can be
 227      =2  // used to force periodic processing of a specific connection.
 228      =2  //
 229      =2  // \param conn A pointer to the uip_conn struct for the connection to
 230      =2  // be processed.
 231      =2  //
 232      =2  // \hideinitializer
 233      =2  //
 234      =2  #define uip_periodic_conn(conn) do { uip_conn = conn; \
 235      =2                                       uip_process(UIP_TIMER); } while (0)
 236      =2  
 237      =2  #if UIP_UDP
 238      =2  //
 239      =2  // Periodic processing for a UDP connection identified by its number.
 240      =2  //
 241      =2  // This function is essentially the same as uip_prerioic(), but for
 242      =2  // UDP connections. It is called in a similar fashion as the
