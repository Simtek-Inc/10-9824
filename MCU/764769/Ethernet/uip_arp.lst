 309      =2  //    hwsend(&uip_buf[0], UIP_LLH_LEN);
C51 COMPILER V8.06   UIP_ARP                                                               03/17/2026 10:18:44 PAGE 23  

 310      =2  //    hwsend(&uip_buf[UIP_LLH_LEN], 40);
 311      =2  //    hwsend(uip_appdata, uip_len - 40 - UIP_LLH_LEN);
 312      =2  // }
 313      =2  // \endcode
 314      =2  //
 315      =2  //extern byte xdata uip_buf[UIP_BUFSIZE+2];
 316      =2  
 317      =2  // @} //
 318      =2  void uip_listen(uint port);
 319      =2  
 320      =2  //-----------------------------------------------------------------------------------//
 321      =2  // Functions that are used by the uIP application program. Opening and
 322      =2  // closing connections, sending and receiving data, etc. is all
 323      =2  // handled by the functions below.
 324      =2  //
 325      =2  //
 326      =2  // \defgroup uipappfunc uIP application functions
 327      =2  // @{
 328      =2  //
 329      =2  // Functions used by an application running of top of uIP.
 330      =2  //
 331      =2  
 332      =2  // Start listening to the specified port.
 333      =2  //
 334      =2  // \note Since this function expects the port number in network byte
 335      =2  // order, a conversion using HTONS() or htons() is necessary.
 336      =2  //
 337      =2  // \code
 338      =2  // uip_listen(HTONS(80)); 
 339      =2  // \endcode
 340      =2  //
 341      =2  // \param port A 16-bit port number in network byte order.
 342      =2  //
 343      =2  void uip_listen(uint port);
 344      =2  
 345      =2  // Stop listening to the specified port.
 346      =2  //
 347      =2  // \note Since this function expects the port number in network byte
 348      =2  // order, a conversion using HTONS() or htons() is necessary.
 349      =2  //
 350      =2  // \code
 351      =2  // uip_unlisten(HTONS(80)); 
 352      =2  // \endcode
 353      =2  //
 354      =2  // \param port A 16-bit port number in network byte order.
 355      =2  //
 356      =2  
 357      =2  struct uip_conn *uip_connect(uint *ripaddr, uint port);
 358      =2  
 359      =2  // Connect to a remote host using TCP.
 360      =2  //
 361      =2  // This function is used to start a new connection to the specified
 362      =2  // port on the specied host. It allocates a new connection identifier,
 363      =2  // sets the connection to the SYN_SENT state and sets the
 364      =2  // retransmission timer to 0. This will cause a TCP SYN segment to be
 365      =2  // sent out the next time this connection is periodically processed,
 366      =2  // which usually is done within 0.5 seconds after the call to
 367      =2  // uip_connect().
 368      =2  //
 369      =2  // \note This function is avaliable only if support for active open
 370      =2  // has been configured by defining UIP_ACTIVE_OPEN to 1 in uipopt.h.
 371      =2  //
C51 COMPILER V8.06   UIP_ARP                                                               03/17/2026 10:18:44 PAGE 24  

 372      =2  // \note Since this function requires the port number to be in network
 373      =2  // byte order, a convertion using HTONS() or htons() is necessary.
 374      =2  //
 375      =2  // \code
 376      =2  // uint ipaddr[2];
 377      =2  
 378      =2  // uip_ipaddr(ipaddr, 192,168,1,2);
 379      =2  // uip_connect(ipaddr, HTONS(80)); 
 380      =2  // \endcode
 381      =2  // 
 382      =2  // \param ripaddr A pointer to a 4-byte array representing the IP
 383      =2  // address of the remote hot.
 384      =2  //
 385      =2  // \param port A 16-bit port number in network byte order.
 386      =2  //
 387      =2  // \return A pointer to the uIP connection identifier for the new connection,
 388      =2  // or NULL if no connection could be allocated.   
 389      =2  // 
 390      =2  //
 391      =2  struct uip_conn *uip_connect(uint *ripaddr, uint port);
 392      =2  
 393      =2  //
 394      =2  // \internal
 395      =2  //
 396      =2  // Check if a connection has outstanding (i.e., unacknowledged) data.
 397      =2  //
 398      =2  // \param conn A pointer to the uip_conn structure for the connection.
 399      =2  //
 400      =2  // \hideinitializer
 401      =2  //
 402      =2  #define uip_outstanding(conn) ((conn)->len)
 403      =2  
 404      =2  //
 405      =2  // Send data on the current connection.
 406      =2  //
 407      =2  // This function is used to send out a single segment of TCP
 408      =2  // data. Only applications that have been invoked by uIP for event
 409      =2  // processing can send data. 
 410      =2  //
 411      =2  // The amount of data that actually is sent out after a call to this
 412      =2  // funcion is determined by the maximum amount of data TCP allows. uIP
 413      =2  // will automatically crop the data so that only the appropriate
 414      =2  // amount of data is sent. The function uip_mss() can be used to query
 415      =2  // uIP for the amount of data that actually will be sent.
 416      =2  // 
 417      =2  // \note This function does not guarantee that the sent data will
 418      =2  // arrive at the destination. If the data is lost in the network, the
 419      =2  // application will be invoked with the uip_rexmit() event being
 420      =2  // set. The application will then have to resend the data using this
 421      =2  // function.
 422      =2  // 
 423      =2  // \param data A pointer to the data which is to be sent.
 424      =2  //
 425      =2  // \param len The maximum amount of data bytes to be sent.
 426      =2  //
 427      =2  // \hideinitializer
 428      =2  //
 429      =2  #define uip_send(data, len) do { uip_sappdata = (data); uip_slen = (len);} while(0)   
 430      =2  
 431      =2  //
 432      =2  // The length of any incoming data that is currently avaliable (if avaliable)
 433      =2  // in the uip_appdata buffer.
C51 COMPILER V8.06   UIP_ARP                                                               03/17/2026 10:18:44 PAGE 25  

 434      =2  //
 435      =2  // The test function uip_data() must first be used to check if there
 436      =2  // is any data available at all.
 437      =2  //
 438      =2  // \hideinitializer
 439      =2  //
 440      =2  #define uip_datalen()       uip_len
 441      =2  
 442      =2  //
 443      =2  // The length of any out-of-band data (urgent data) that has arrived
 444      =2  // on the connection.
 445      =2  //
 446      =2  // \note The configuration parameter UIP_URGDATA must be set for this
 447      =2  // function to be enabled.
 448      =2  //
 449      =2  // \hideinitializer
 450      =2  //
