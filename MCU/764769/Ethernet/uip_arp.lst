 691      =2  //
 692      =2  // Convert 16-bit quantity from host byte order to network byte order.
 693      =2  //
 694      =2  // This macro is primarily used for converting constants from host
 695      =2  // byte order to network byte order. For converting variables to
 696      =2  // network byte order, use the htons() function instead.
 697      =2  //
 698      =2  // \hideinitializer
 699      =2  //
 700      =2  #ifndef HTONS
 701      =2  #if BYTE_ORDER == BIG_ENDIAN
 702      =2  #define HTONS(n) (n)
 703      =2  #else // BYTE_ORDER == BIG_ENDIAN //
           =2 #define HTONS(n) ((((uint)((n) & 0xff)) << 8) | (((n) & 0xff00) >> 8))
           =2 #endif // BYTE_ORDER == BIG_ENDIAN //
 706      =2  #endif // HTONS //
 707      =2  
 708      =2  //
 709      =2  // Convert 16-bit quantity from host byte order to network byte order.
