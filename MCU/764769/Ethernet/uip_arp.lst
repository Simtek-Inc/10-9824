 245      =2  //  for(i = 0; i < UIP_UDP_CONNS; i++) {
 246      =2  //    uip_udp_periodic(i);
 247      =2  //    if(uip_len > 0) {
C51 COMPILER V8.06   UIP_ARP                                                               03/17/2026 10:18:44 PAGE 22  

 248      =2  //      devicedriver_send();
 249      =2  //    }
 250      =2  //  }   
 251      =2  // \endcode
 252      =2  //
 253      =2  // \note As for the uip_periodic() function, special care has to be
 254      =2  // taken when using uIP together with ARP and Ethernet:
 255      =2  // \code
 256      =2  //  for(i = 0; i < UIP_UDP_CONNS; i++) {
 257      =2  //    uip_udp_periodic(i);
 258      =2  //    if(uip_len > 0) {
 259      =2  //      uip_arp_out();
 260      =2  //      ethernet_devicedriver_send();
 261      =2  //    }
 262      =2  //  }   
 263      =2  // \endcode
 264      =2  //
 265      =2  // \param conn The number of the UDP connection to be processed.
 266      =2  //
 267      =2  // \hideinitializer
 268      =2  //
 269      =2  #define uip_udp_periodic(conn) do { uip_udp_conn = &uip_udp_conns[conn]; \
 270      =2                                  uip_process(UIP_UDP_TIMER); } while (0)
 271      =2  
 272      =2  //
 273      =2  // Periodic processing for a UDP connection identified by a pointer to
 274      =2  // its structure.
 275      =2  //
 276      =2  // Same as uip_udp_periodic() but takes a pointer to the actual
 277      =2  // uip_conn struct instead of an integer as its argument. This
 278      =2  // function can be used to force periodic processing of a specific
 279      =2  // connection.
 280      =2  //
 281      =2  // \param conn A pointer to the uip_udp_conn struct for the connection
 282      =2  // to be processed.
 283      =2  //
 284      =2  // \hideinitializer
 285      =2  //
 286      =2  #define uip_udp_periodic_conn(conn) do { uip_udp_conn = conn; \
 287      =2                                           uip_process(UIP_UDP_TIMER); } while (0)
 288      =2  
 289      =2  void uip_udp_listen(uint port);
 290      =2  void uip_udp_unlisten(uint port);
 291      =2  
 292      =2  #endif // UIP_UDP //
 293      =2  
 294      =2  // The uIP packet buffer.
 295      =2  //
 296      =2  // The uip_buf array is used to hold incoming and outgoing
 297      =2  // packets. The device driver should place incoming data into this
 298      =2  // buffer. When sending data, the device driver should read the link
 299      =2  // level headers and the TCP/IP headers from this buffer. The size of
