           =2 #define     SI_WR                   BIT0
           =2 #define     SI_RD                   BIT1
           =2 
           =2 #define     FLASH_WR_ENB            (PCON |= PWE_)
           =2 #define     FLASH_WR_DISB           (PCON &= ~PWE_)
           =2 
           =2 #endif  // end of TYPES_H //
