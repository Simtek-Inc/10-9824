 155   1          pCfgPkt->Netmask                   = gconfig_ConfigData.Netmask;
 156   1          pCfgPkt->EthernetTxTimer           = gconfig_ConfigData.EthernetTxTimer;
 157   1          pCfgPkt->pw                        = gconfig_ConfigData.pw;
