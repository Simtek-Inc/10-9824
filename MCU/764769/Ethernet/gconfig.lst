 669          // Name    : gconfig_Checksum
 670          // Purpose :
 671          // Params  :
 672          // Returns :
 673          // Note    :
 674          //----------------------------------------------------------------------------------------
 675          static uint  gconfig_Checksum(uint  *pBuf, ulong length)
 676          {
 677   1              ulong   cksum = 0;
 678   1              ulong   i, count;
 679   1              byte*   inChar = &pBuf;
 680   1              uint *  point;
 681   1      
 682   1              count = length/2;
 683   1      
 684   1          for (i = 0; i < count; i++)
 685   1            {
 686   2            point = pBuf;
 687   2            cksum += *pBuf++;
 688   2            if (point > pBuf)
 689   2              (*inChar) = *inChar + 1;
 690   2      
 691   2            if (!(i % 0x8000))
 692   2              {
 693   3              cksum = (cksum >> 16) + (cksum & 0xffff);
 694   3              cksum += (cksum >> 16);
 695   3              cksum &= 0xffff;
 696   3              }
 697   2            }
 698   1                  
 699   1          if (length % 2)
 700   1            cksum += (*pBuf & 0xff00);
 701   1      
 702   1          cksum  = (cksum >> 16) + (cksum & 0xffff);
 703   1          cksum += (cksum >> 16);
 704   1          cksum &= 0xffff;
 705   1      
 706   1          return ((uint)cksum);
 707   1      } // End of gconfig_Checksum() //
