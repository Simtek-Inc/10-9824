 716          static void gconfig_DisplayConfigData(GCONFIG_CFG_DATA *pConfigData)
 717          {
 718   1          byte  i, tmp, *pData;
 719   1          uint  val;
 720   1      
 721   1          if (GS2E_GetTaskState() == GS2E_STATE_IDLE)
 722   1            {
 723   2            printd("  Device Name           : ");
 724   2            for (i = 0; i < 16; i++)
 725   2              printd ("%c", pConfigData->DevName.DevName[i]);
 726   2      
 727   2            printd("\n\r");
 728   2            printd("  MAC Address           : ");
 729   2            for (i = 0; i < 6; i++)
 730   2              printd ("%02bx ", macAddr.MacAddr[i]);
 731   2            printd("\n\r");
 732   2            printd("  Network Settings      : ");
 733   2            printd ("%04dx\r\n", pConfigData->Network);
