 735   2            if (val & GCONFIG_NETWORK_CLIENT)
 736   2              printd("    Server/Client       : Client");
 737   2            else
 738   2              printd("    Server/Client       : Server");
 739   2            printd("\n\r");
 740   2            if (val & GCONFIG_NETWORK_DHCP_ENABLE)
 741   2              printd("    DHCP                : Enabled");
 742   2            else
 743   2              printd("    DHCP                : Disabled");
 744   2            printd("\n\r");
 745   2            if (val & GCONFIG_NETWORK_PROTO_UDP)
 746   2              printd("    UDP                 : On");
 747   2            else
 748   2              printd("    UDP                 : Off");
 749   2            if (val & GCONFIG_NETWORK_PROTO_TCP)
 750   2              printd("          TCP         : On");
 751   2            else
 752   2              printd("               TCP   : Off");
 753   2            printd("\n\r");
 754   2            if (val & GCONFIG_NETWORK_PROTO_UDP_BCAST)
 755   2              printd("    BroadCast           : On");
 756   2            else
 757   2              printd("    BroadCast           : Off");
 758   2            printd("\n\r");
 759   2            printd("  Device Server IP      : ");
 760   2            tmp    = 0;
 761   2            pData  = (byte *)&pConfigData->ServerStaticIP;
 762   2            for (i = 0; i < 3; i++)
 763   2              tmp += printd ("%bu.", *(pData + i));
 764   2            tmp   += printd ("%bu", *(pData + i));
 765   2            tmp    = 17 - tmp;                                                                     // find the n
             -umber of characters of IP 255.255.255.255(15) plus white space(3) minus the number printed
 766   2            if (tmp < 0) tmp = 0;
 767   2            for(i  = 0; i < tmp; i++)
 768   2              printd(" ");
 769   2            printd("Port  : ");
 770   2            printd("%du(%04dx)", pConfigData->ServerDataPktListenPort, pConfigData->ServerDataPktListenPort);
 771   2            printd("\n\r");
 772   2      // Client Port Information
 773   2            tmp    = 0;
 774   2            printd("  Host Server IP        : ");
 775   2            pData  = (byte *)&pConfigData->ClientDestIP;
C51 COMPILER V8.06   GCONFIG                                                               03/17/2026 10:18:45 PAGE 76  

 776   2            for (i = 0; i < 3; i++)
 777   2              tmp += printd ("%bu.", *(pData + i));
 778   2            tmp   += printd ("%bu", *(pData + i));
 779   2            tmp    = 17 - tmp;                                                                     // find the n
             -umber of characters of IP 255.255.255.255(15) plus white space(3) minus the number printed
 780   2            if (tmp < 0) tmp = 0;
 781   2            for(i  = 0; i < tmp; i++)
 782   2              printd(" ");
 783   2            printd("Port  : ");
 784   2            printd("%du(%04dx)", pConfigData->ClientDestPort, pConfigData->ClientDestPort);
 785   2            printd("\n\r");
 786   2            }
 787   1      } // End of gconfig_DisplayConfigData() //
