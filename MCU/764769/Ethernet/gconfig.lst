 246          // Name    : Simtek_Modes_Enable
 247          // Purpose : use data stored with EDCT tool to enable different functions
 248          // Params  : mask of bit to check for enable/disable of desired function
 249          // Returns : ON if enabled, OFF if not
 250          // Note    :
 251          // ---------------------------------------------------------------------------------------
 252          //
 253          byte Simtek_Modes_Enable(byte mask)
 254          {
 255   1          if ((gconfig_ConfigData.Option & mask) == 0)                                        // mask off all ot
             -her bits and check remaing bit/s for state
 256   1            return OFF;                                                                       // debug if enable
             -d turn mode off
 257   1          return ON;                                                                          // debug if disabl
             -ed turn mode on
 258   1      } //End of Simtek_Modes_Enable(byte mask) //
