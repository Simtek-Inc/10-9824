 260          //----------------------------------------------------------------------------------------
 261          // Name    : GCONFIG_IpAddr2Ulong()
 262          // Purpose :
 263          // Params  :
 264          // Returns :
 265          // Note    :
 266          //----------------------------------------------------------------------------------------
 267          ulong GCONFIG_IpAddr2Ulong(byte* pBuf, byte len)
 268          {
 269   1          ulong ip     = 0;
 270   1          byte* point  = (byte*)&ip;
 271   1          byte  count  = 0;
 272   1          byte  count2 = 0;
 273   1      
 274   1          while (1)
 275   1            {
 276   2            count2 = 0;
 277   2            while ((*pBuf != '.') && len)
 278   2              {
 279   3              count2++;
 280   3              if (count2 > 3) return 0xffffffff;
 281   3      
C51 COMPILER V8.06   GCONFIG                                                               03/17/2026 10:18:45 PAGE 68  

 282   3              *point *= 10;
 283   3        
 284   3              if ((*pBuf < 0x3a) && (*pBuf > 0x2f))
 285   3                *point += (*pBuf - 0x30);
 286   3              else
 287   3                return 0xffffffff;
 288   3      
 289   3              pBuf++;
 290   3              len--;
 291   3              }
 292   2        
 293   2            if (len == 0) break;
 294   2      
 295   2            pBuf++;
 296   2            len--;
 297   2            count++;
 298   2            point++;
 299   2      
 300   2            if (count > 3) return 0xffffffff;
 301   2            }
 302   1      
 303   1          if (count != 3) return 0xffffffff;
 304   1      
 305   1          return ip;
 306   1      } //End of GCONFIG_IpAddr2Ulong() //
