 592          // Name    : gconfig_ReStoreParameter
 593          // Purpose : read back the ethernet configuration data at startup or reboot 
 594          // Params  : addr - base address to read from
 595          //                  pBase - pointer to the location to write data to(RAM), or read data from(FLASH)
 596          //                  len - number of bytes to read back
 597          // Returns : False if an error occurs during read (bad data, or faulty checksum)
 598          //                  True if all reads and writes completed sucessfully and check sums match
 599          // Note    : All the procedeing notes and following comments were added by cjm and are the assumed functio
             -ns.
 600          //                  This block was left blank by the ASIX software engineers.
 601          //----------------------------------------------------------------------------------------
 602          static bool gconfig_ReStoreParameter(ulong addr, GCONFIG_CFG_DATA *pConfig, uint  len)
 603          {
 604   1              uint    i;
 605   1              byte    *pParaBaseByte;
 606   1              byte    lastWtst = 0;
 607   1      
 608   1              pParaBaseByte = (byte *)pConfig;
 609   1      
 610   1              lastWtst = WTST;
 611   1              WTST = PROG_WTST_7;
 612   1              if (CSREPR & PMS) // SRAM shadow
 613   1                {
 614   2                CSREPR |= FAES;
 615   2                for (i = 0 ; i < len ; i++)
 616   2                  {
 617   3                  *(pParaBaseByte + i) = FCVAR(byte, GCONFIG_CFG_DATA_FLASH_ADDR + addr + i);
 618   3                  }
 619   2                CSREPR &= ~FAES;
 620   2                }
 621   1              else
 622   1                {
 623   2                CSREPR &= ~FAES;
 624   2                for (i = 0 ; i < len ; i++)
 625   2                  {
 626   3                  *(pParaBaseByte + i) = FCVAR(byte, GCONFIG_CFG_DATA_FLASH_ADDR + addr + i);
 627   3                  }
 628   2                }
 629   1              WTST = lastWtst;
 630   1      
 631   1              if (0xffff != gconfig_Checksum((uint  *)pConfig, len))
 632   1                {
 633   2                printd("failed! (wrong checksum)\n\r");
 634   2                return FALSE;
 635   2                }
 636   1              else if (pConfig->CfgLength != len)
 637   1                {
 638   2                printd("Invalid configuration data!\n\r");
 639   2                return FALSE;
 640   2                }
 641   1              printd("pass\n\r");
 642   1              return TRUE;
 643   1      } // End of gconfig_ReStoreParameter() //
