C51 COMPILER V8.06   STOE                                                                  07/01/2021 16:27:12 PAGE 40  

 161          //-----------------------------------------------------------------------------
 162          // Function Name: stoe_BdpInit
 163          // Purpose: initial Buffer Descriptor Page.
 164          // Params:
 165          // Returns:
 166          // Note:
 167          // ----------------------------------------------------------------------------
 168          void stoe_BdpInit(void)
 169          {
 170   1              uint    page = (STOE_BDP_START_ADDR >> 8);
 171   1      
 172   1              PBDP = STOE_BDP_START_ADDR;
 173   1      
 174   1              // set BDP number
 175   1              PBDP->BDP_ID = 0;
 176   1      
 177   1              // set rcv buffer.
 178   1              PBDP->RSPP = page + 1;
 179   1              PBDP->REPP = page + PAGES_OF_RCV;
 180   1              PBDP->RHPR = PBDP->RSPP;
 181   1              PBDP->RTPR = PBDP->RSPP;
 182   1              PBDP->RFP = PAGES_OF_RCV;
 183   1      
 184   1              // set xmit buffer.
 185   1              PBDP->TSPP = page + 1 + PAGES_OF_RCV;
 186   1              PBDP->TEPP = page + PAGES_OF_RCV + PAGES_OF_XMIT;
 187   1              PBDP->THPR = PBDP->TSPP;
 188   1              PBDP->TTPR = PBDP->TSPP;
 189   1              PBDP->TFP = PAGES_OF_XMIT;
 190   1      
 191   1              // set rcv and xmit start/end buffer address.
 192   1              PBDP->RcvStartAddr = STOE_BDP_START_ADDR + 256;
 193   1              PBDP->XmtStartAddr = PBDP->RcvStartAddr + STOE_RCV_BUF_SIZE;
 194   1              PBDP->RcvEndAddr = PBDP->XmtStartAddr - 1;
 195   1              PBDP->XmtEndAddr = PBDP->XmtStartAddr + STOE_XMIT_BUF_SIZE - 1;
 196   1      
 197   1      } // End of stoe_BdpInit
