 453          // Function Name: STOE_Send
 454          // Purpose:     Call this function to set add STOE header.
 455          // Params:      pbuf : buffer address, must between TSPP and TEPP.
 456          //                      length : packet length.
 457          //                      protocol : if the packet is ip packet, set the ip layer protocol,
 458          //                                              if not a ip packet, set value to 0xff.
 459          // Returns:
 460          // Note:
 461          // ----------------------------------------------------------------------------
 462          void STOE_Send(byte XDATA* pbuf, uint length, byte protocol)
 463          {
 464   1              STOE_FRAME_HEADER XDATA*        pframe =        (STOE_FRAME_HEADER XDATA*)pbuf;
 465   1              byte    occupypages = PBDP->STOE_TxInform.Pages;
 466   1              byte    isr;
 467   1      
 468   1              pframe->Length = length;
 469   1              pframe->Protocol = protocol;
 470   1      
C51 COMPILER V8.06   STOE                                                                  07/01/2021 16:27:12 PAGE 45  

 471   1              isr = EA;
 472   1              EA = 0;
 473   1              PBDP->TFP -= occupypages;
 474   1              EA = isr;
 475   1      
 476   1              PBDP->TTPR += occupypages;
 477   1              if (PBDP->TTPR > PBDP->TEPP)
 478   1                      PBDP->TTPR = PBDP->TSPP + PBDP->TTPR - PBDP->TEPP - 1;
 479   1      
 480   1              pframe->NPR = PBDP->TTPR;
 481   1      
 482   1              stoe_XmitHandle();
 483   1      
 484   1      } // End of STOE_Send()
