 278          // ----------------------------------------------------------------------------
 279          // Function Name: STOE_ProcessInterrupt
 280          // Purpose: programmer can call this function by polling type to find that
 281          //                      interrupt event had happened.
 282          // Params:
 283          // Returns:
 284          // Note:
C51 COMPILER V8.06   STOE                                                                  07/01/2021 16:27:12 PAGE 42  

 285          // ----------------------------------------------------------------------------
 286          void STOE_ProcessInterrupt(void)
 287          {
 288   1              static byte XDATA       int_status;
 289   1              byte XDATA                      temp;
 290   1      
 291   1              while (1)
 292   1              {
 293   2                      // read stoe interrupt status
 294   2                      stoe_ReadReg(STOE_INT_STATUS_REG, &int_status, 1);
 295   2                      int_status &= STOE_DEFAULT_INT_MASK;
 296   2      
 297   2                      if (!int_status)
 298   2                              break;
 299   2      
 300   2                      if (int_status & RCV_PACKET)
 301   2                      {
 302   3                              while (PBDP->RFP < PAGES_OF_RCV)
 303   3                                      stoe_RcvHandle();
 304   3                      }
 305   2                      if (int_status & RCV_BUF_RING_FULL)
 306   2                      {
 307   3      //                      printd ("\rRX Packet Buffer Ring is Full.\n\r");
 308   3                              temp = RESUME_PKT_RCV;
 309   3                              stoe_WriteReg(STOE_L4_CMD_REG, &temp, 1);
 310   3                      }
 311   2              }
 312   1      }
