 255          // ----------------------------------------------------------------------------
 256          // Function Name: STOE_Start
 257          // Purpose: enable all used interrupts and set some register to start
 258          //                      timer, software-dma and processing received packets.
 259          // Params:
 260          // Returns:
 261          // Note:
 262          // ----------------------------------------------------------------------------
 263          void STOE_Start(void)
 264          {
 265   1              byte XDATA      temp;
 266   1      
 267   1              // clear interrupt status
 268   1              stoe_ReadReg(STOE_INT_STATUS_REG, &temp, 1);
 269   1              // start STOE L2/L3/L4 engines
 270   1              stoe_StartOperate();
 271   1              // start DMA module
 272   1              DMA_Start();
 273   1              // start MAC module
 274   1              MAC_Start();
 275   1              EXTINT4(1);     // Enable INT4 interrupt for stoe & mac modules.
 276   1      } // End of STOE_Start
