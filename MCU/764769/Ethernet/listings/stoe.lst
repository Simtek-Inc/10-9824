 557          // Function Name: STOE_CHECK_MAC
 558          // Purpose: 
 559          // Params: 
 560          // Returns:
 561          // Note:
 562          // ----------------------------------------------------------------------------
 563          byte STOE_CHECK_MAC(ulong *ip_addr)
 564          {
 565   1              byte entry_addr, result[6] = {0};
 566   1            
 567   1              entry_addr = (byte)(*ip_addr & 0x7F) * 2;
 568   1      //      PRINTD(DEBUG_MSG, ("STOE_CHECK_MAC :: entry_addr = %bx\n\r", entry_addr));
 569   1              stoe_WriteReg(STOE_ARP_ADDR_REG, &entry_addr, 1);
 570   1      
 571   1              entry_addr = ARP_CACHE_CMD_READ | ARP_CACHE_CMD_GO;
 572   1              stoe_WriteReg(STOE_ARP_CMD_REG, &entry_addr, 1);
 573   1      
 574   1              stoe_ReadReg(STOE_ARP_DATA_REG, result, 6);
 575   1      
 576   1              if (result[0]& 0x80)
 577   1                      return 1;
 578   1              
 579   1              return 0;
 580   1      
 581   1      } // End of STOE_CHECK_MAC()
