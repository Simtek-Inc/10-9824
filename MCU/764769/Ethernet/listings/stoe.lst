 515          //-----------------------------------------------------------------------------
 516          // Function Name: STOE_CopyCode2TPBR
 517          // Purpose: 
 518          // Params: 
 519          // Returns:
 520          // Note:
 521          // ----------------------------------------------------------------------------
 522          byte XDATA* STOE_CopyCode2TPBR(byte XDATA* pdest, byte* psour, uint length)
 523          {
 524   1              uint    space, leftlen;
 525   1      
 526   1              // destination address is not in range of TPBR.
 527   1              if ((pdest > PBDP->XmtEndAddr) || (pdest < PBDP->XmtStartAddr))
 528   1                      return 0;
 529   1      
 530   1              space = (uint)PBDP->XmtEndAddr - (uint)pdest + 1;
 531   1              if (space > length)
 532   1              {
C51 COMPILER V8.06   STOE                                                                  07/01/2021 16:27:12 PAGE 46  

 533   2                      while (length--)
 534   2                              *pdest++ = *psour++;
 535   2              }
 536   1              else
 537   1              {
 538   2                      leftlen = length - space;
 539   2      
 540   2                      while (space--)
 541   2                              *pdest++ = *psour++;
 542   2      
 543   2                      pdest = PBDP->XmtStartAddr;
 544   2      
 545   2                      while (leftlen--)
 546   2                              *pdest++ = *psour++;
 547   2              }
 548   1      
 549   1              return pdest;
 550   1      
 551   1      } // End of STOE_CopyCode2TPBR
