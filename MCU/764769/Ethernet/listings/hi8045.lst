 166          //----------------------------------------------------------------------------------------
 167          // Function Name : writeHI8045                                                            //
 168          // Purpose       : write the data into the HI-8045 device, 85 bits at a time              //
 169          // Params        : data to write to registers                                             //
 170          // Returns       : void                                                                   //
 171          // Note          :                                                                        //
 172          //----------------------------------------------------------------------------------------
 173          void writeHI8045(byte dat[10])                                                            //
 174          {
 175   1          byte i,j;
 176   1          
 177   1          HI8045LOAD  = 1;                                                                      // make sure the
             - fpga ale is deactived before starting
 178   1          HI8045CLK   = 1;                                                                      // make sure the
             - fpga serial register clock is deactived before starting
 179   1          HI8045LOAD  = 0;                                                                      // activate the 
             -ale to move the address into the address latch from the sipo function
 180   1          HI8045CS    = 0;
 181   1          for(i=0; i<5; i++)                                                                    // HI-8045 has 8
C51 COMPILER V8.06   HI8045                                                                07/01/2021 16:27:15 PAGE 9   

             -5 bits shift register, but only 80 can be used. Insert 0's into first 5 bits.
 182   1          {
 183   2              HI8045DIN   = 0;
 184   2              HI8045CLK   = 0;          
 185   2              HI8045CLK   = 0;                                                                  // deactivate th
             -e fpga serial register clock
 186   2              HI8045CLK   = 0;                                                                  // deactivate th
             -e fpga serial register clock
 187   2              HI8045CLK   = 0;                                                                  // deactivate th
             -e fpga serial register clock
 188   2              HI8045CLK   = 0;   
 189   2              HI8045CLK   = 1;                                                                  // set the clock
             - to activate
 190   2              HI8045CLK   = 1;                                                                  // set the clock
             - to activate
 191   2          }
 192   1       
 193   1          for (i = 0; i < 10; i++)                                                              // loop until al
             -l bits are read
 194   1          {
 195   2              for (j = 0; j < 8; j++)                                                           // loop until al
             -l bits are read
 196   2              {
 197   3                  HI8045DIN = dat[i];                                                           // write the bit
             - of the data to the fpga data input pin
 198   3                  HI8045DIN = dat[i];                                                           // burn a ccyle
 199   3                  HI8045CLK = 0;                                                                // deactivate th
             -e fpga serial register clock
 200   3                  HI8045CLK = 0;                                                                // deactivate th
             -e fpga serial register clock
 201   3                  HI8045CLK = 0;                                                                // deactivate th
             -e fpga serial register clock
 202   3                  HI8045CLK = 0;                                                                // burn a ccyle
 203   3                  dat[i]    = dat[i] >> 1;                                                      // shift the nex
             -t bit into position for the next bit write
 204   3                  HI8045CLK = 1;                                                                // set the clock
             - to activate
 205   3                  HI8045CLK = 1;                                                                // set the clock
             - to activate
 206   3                  
 207   3                  HI8045CLK   = 1;                                                              // set the clock
             - to high to burn a cycle
 208   3                  HI8045LOAD  = 1;                                                              // now that the 
             -address is latched deactivate the ale
 209   3                  HI8045DIN   = 1;                                                              // write the bit
             - of the data to the fpga data input pin
 210   3                  HI8045CS    = 1;
 211   3              }
 212   2          }
 213   1      }
