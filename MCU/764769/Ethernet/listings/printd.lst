 222   4                                              else if (*format == 'u')
 223   4                          pc += printi ( va_arg( args, ulong ), 10, 0, width, pad, 'a');
 224   4                                              else if (*format == 'x')
 225   4                          pc += printi ( va_arg( args, ulong ), 16, 0, width, pad, 'a');
 226   4                                              continue;
 227   4                              }
 228   3                      }
 229   2                else
 230   2                  {
 231   3                      out:
 232   3                              DEBUG_PORT_PUTCHR(*format);
 233   3                              ++pc;
 234   3                      }
 235   2              }
 236   1              va_end(args);
 237   1              return pc;
 238   1      }
