  84          // Note    : None
  85          //--------------------------------------------------------------------------------
  86          static int printi(long i, int b, int sg, int width, int pad, int letbase)
  87          {//  i       == value
  88   1       //  b       == number base
  89   1       //  sg      == signed numer 1 = yes, 0 = no
  90   1       //  width   == width of string
  91   1       //  pad     == pad flags
  92   1       //  letbase ==
  93   1              char print_buf[PRINT_BUF_LEN];
  94   1              register char *s;
  95   1              register long t, neg = 0, pc = 0;
  96   1              register unsigned long u = i;
  97   1      
  98   1              if (i == 0)
  99   1                {
 100   2                      print_buf[0] = '0';
 101   2                      print_buf[1] = '\0';
 102   2                      return prints ( print_buf, width, pad);
 103   2              }
 104   1              if (sg && b == 10 && i < 0)
 105   1                {
 106   2                      neg = 1;
 107   2                      u = -i;
 108   2              }
 109   1              s = print_buf + PRINT_BUF_LEN-1;
 110   1              *s = '\0';
 111   1              while (u)
 112   1                {
 113   2                      t = u % b;
 114   2                      if( t >= 10 )
 115   2                              t += letbase - '0' - 10;
 116   2                      *--s = t + '0';
 117   2                      u /= b;
 118   2              }
 119   1              if (neg)
 120   1                {
 121   2                if( width && (pad & PAD_ZERO) )
 122   2                  {
 123   3                              DEBUG_PORT_PUTCHR ('-');
 124   3                              ++pc;
 125   3                              --width;
 126   3                      }
 127   2                else
 128   2                  { *--s = '-'; }
 129   2              }
 130   1              return pc + prints(s, width, pad);
 131   1      }
