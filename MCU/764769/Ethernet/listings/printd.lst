 141          // Note    : None
 142          //--------------------------------------------------------------------------------
 143          int printd(const char *format, ...)
 144          {
 145   1              register int width, pad;
 146   1              register int pc = 0;
 147   1              char scr[2];
 148   1              
 149   1          va_list args;
 150   1          
 151   1          if (DEBUG_MsgEnable == 0)
 152   1              return 0;
 153   1      
 154   1          va_start( args, format );
 155   1              for (; *format != 0; ++format)
 156   1                {
 157   2                if (*format == '%')
 158   2                  {
 159   3                              ++format;
 160   3                              width = pad = 0;
 161   3                              if (*format == '\0') break;
 162   3                              if (*format == '%') goto out;
 163   3                  if (*format == '-') 
 164   3                    {
 165   4                                      ++format;
