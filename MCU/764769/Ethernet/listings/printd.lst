 167   4                              }
 168   3                  while (*format == '0')
 169   3                    {
 170   4                                      ++format;
 171   4                                      pad |= PAD_ZERO;
 172   4                              }
 173   3                  for ( ; *format >= '0' && *format <= '9'; ++format)
 174   3                    {
 175   4                                      width *= 10;
 176   4                                      width += *format - '0';
 177   4                              }
 178   3                              switch(*format)
 179   3                              {
 180   4                                      case 'c' :
