 240          //----------------------------------------------------------------------------------------
 241          // name      : printipa
 242          // purpose   : convert long into IPv4 formatted string
 243          // params    : 
 244          // returns   : number of character converted
 245          // note      :
 246          //----------------------------------------------------------------------------------------
 247          int printipa(long i, int width, int pad)
 248          {//  i       == value
 249   1       //  width   == width of string
 250   1       //  pad     == pad flags
 251   1            char  print_buf[PRINT_BUF_LEN];
 252   1            char *s;
 253   1            long  t, pc = 0;
 254   1            ulong u = i;
 255   1            char  x = 0;
 256   1      
 257   1            memset(&print_buf[0], '\0', PRINT_BUF_LEN);
 258   1            s = &print_buf[0] + PRINT_BUF_LEN - 1;
 259   1            *s = '\0';
C51 COMPILER V8.06   PRINTD                                                                07/01/2021 16:27:16 PAGE 13  

 260   1      
 261   1            do
 262   1              {
 263   2              u = (i >> x) & 0xFF;
 264   2              do
 265   2                {
 266   3                t = u % 10;
 267   3                *--s = t + '0';
 268   3                u /= 10;
 269   3                }
 270   2              while (u);
 271   2              x += 8;
 272   2              if((x <= 24))
 273   2                *--s = '.';
 274   2              }
 275   1            while(x < 25);
 276   1      
 277   1            return pc + prints(s, width, pad);
 278   1      }
