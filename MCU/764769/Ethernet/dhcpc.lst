 272   3                              if (dhcp_Retry < DHCP_MAX_RETRY)
 273   3                                      dhcpInfo.State = DHCP_INITIAL_STATE;
 274   3                              else
 275   3                                      dhcpInfo.State = DHCP_IDLE_STATE;
 276   3                      }
 277   2              }
 278   1              return dhcpInfo.State;
 279   1      }
