 263          char DHCP_GetState(void)
 264          {
 265   1              if (dhcpInfo.State & (DHCP_DISCOVER_STATE | DHCP_REQUEST_STATE))
 266   1              {
 267   2                uint  curTime = (uint)SWTIMER_Tick();
 268   2      
 269   2              if ((curTime - dhcp_Time) >= DHCP_REQUEST_TIMEOUT) // had timeout //
 270   2                      {
