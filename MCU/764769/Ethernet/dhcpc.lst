  74          //--------------------------------------------------------------------------------
  75          bool DHCP_Init(void)
  76          {
  77   1              dhcpInfo.AppId = TCPIP_Bind(NULL, DHCP_EventHandle, DHCP_ReceiveHandle); // assigned by TCP stack
  78   1              dhcpInfo.State = DHCP_IDLE_STATE;
  79   1      
  80   1            if(dhcpInfo.AppId == TCPIP_NO_NEW_CONN)
  81   1              return FALSE;
  82   1            else
