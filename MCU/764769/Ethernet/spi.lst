 279           *--------------------------------------------------------------------------------
 280           * void SPI_Setup(unsigned char ctrlCmd, unsigned char intrEnb, unsigned char baudrate, unsigned char slvS
             -el)
 281           * Purpose : Setup the SPI module and initiate SPI function.
 282           * Params  : ctrlCmd - control register value.
 283           *           intrEnb - interrupt source enabled bit.
 284           *           baudrate - a parameterto generate baudrate.
 285           *           slvSel - slave selection bit.
 286           * Returns : None.
 287           * Note    : None.
 288           *--------------------------------------------------------------------------------
 289           */
 290          void SPI_Setup(unsigned char ctrlCmd, unsigned char intrEnb, unsigned char baudrate, unsigned char slvSel)
 291          {
 292   1              unsigned char   spiSlvCmd = 0;
 293   1              unsigned short  i;
 294   1      
 295   1              spiActF = 0;
 296   1              spiCtrl = 0;
 297   1              spiPktDir = 0;
 298   1              spiPktLen = 0;
 299   1              spiLenCnt = 0;
 300   1              spiTransLoop = 0;
 301   1              spiTransLoopCnt = 0;
 302   1              for (i=0 ; i<4 ; i++)
 303   1                      spiRxBuf[i] = 0;
 304   1              for (i=0 ; i<16 ; i++)
 305   1              {
 306   2                      spiSlvTxBuf[i] = 0;
 307   2                      spiSlvRxBuf[i] = 0;
 308   2              }
 309   1      
 310   1              /* Record the SPI control mode */
 311   1              spiCtrl = intrEnb;
 312   1              /* Setup SPI mode */
 313   1              SPI_Cmd(SI_WR, SPICTRLR, &ctrlCmd);
 314   1              /* Enable intertupe flag type of SPI */
 315   1              SPI_Cmd(SI_WR, SPIIER, &intrEnb);
 316   1              /* SPI baud rate selection */
 317   1              SPI_Cmd(SI_WR, SPIBRR, &baudrate);
 318   1              /* SPI slave select */
 319   1              SPI_Cmd(SI_WR, SPISSR, &slvSel);
 320   1              /* SPI slave is ready to receive */
 321   1              spiSlvCmd = SPI_SLV_RDY;
 322   1              SPI_Cmd(SI_WR, SPISCR, &spiSlvCmd);
 323   1      }
