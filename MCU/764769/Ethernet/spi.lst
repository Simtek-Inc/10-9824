                      unsigned char   tempData = 0;
                      unsigned short  i;
              
                      slvCmdType = spiSlvRxBuf[0] & 0xF0;
                      if (slvCmdType == SPI_SLV_SRSFR)
                      {
                              realLen = (spiSlvRxBuf[0] & 0x07) + 1;
                              sfrAddr = spiSlvRxBuf[1];
                              for (i=0 ; i<realLen ; i++)
                              {
