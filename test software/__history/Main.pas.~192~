procedure TMainForm.responseReset;
begin
    memoTx.Clear;                              // Blank the dataout and datain
    memoRx.Clear;                              // Blank the dataout and datain

    mm_reset.Caption                     := '&'+Reset_Command;
    mm_firmware.Caption                  := Firmware_Command;

    mm_send_mult_firmware.Caption        := '&'+Firmware_Command;
    mm_send_mult_status.Caption          := '&'+Status_Command;
    mm_send_mult_dimming.Caption         := '&'+Dimming_Command;
    mm_send_mult_indicator.Caption         := '&'+Indicator_Command;


    lblScrollRate.caption   := 'Scroll Rate Value: ' + InttoStr(tkbScrollRate.Position);

    lblFirmwareValue1.Caption        := Firmware_Default_Value;
    lblFirmwareValue2.Caption        := Firmware_Default_Value;
    lblFirmwareValue3.Caption        := Firmware_Default_Value;


    tkbDimming1Old       := 0;
    tkbDimming1.Position := 0;
    lblDimming1.Caption  := lblDimming1Cap + '0';

    tkbDimming2Old       := 0;
    tkbDimming2.Position := 0;
    lblDimming2.Caption  := lblDimming2Cap + '0';


    MainForm.Caption                 := buildMainCaption;       //
    lblTransmitRate.Caption          := TSCapHeader + '0.00Hz';

    lbl_Firmware_TX_Rate.Caption     := Firmware_Caption_Header + '0.00Hz';
    lbl_Status_TX_Rate.Caption       := Status_Caption_Header + '0.00Hz';
    lbl_Dimming_TX_Rate.Caption      := Dimming_Caption_Header + '0.00Hz';

    lblTestSoftwarePNValue.Caption   := lblTestSoftwareCap;
    lblTestSoftwareRevValue.Caption  := lblTestSoftwareRev;

    cpSetComPort;


    MainForm.KeyPreview := False;
end;

procedure TMainForm.responseFirmware(s : string);
var
  si    : string;
  b1,b2 : byte;
begin
    inc(NumberOfResponse);
    b2 := Ord(s[2]);
    b1 := ((b2 shr 4) and $0F) or $30;
    b2 := (b2 and $0F) or $30;
    si := ': ' + chr(b1) + chr(b2) + '-';
    b2 := Ord(s[3]);
    b1 := ((b2 shr 4) and $0F) or $30;
    b2 := (b2 and $0F) or $30;
    si := si + chr(b1) + chr(b2);
    b2 := Ord(s[4]);
    b1 := ((b2 shr 4) and $0F) or $30;
    b2 := (b2 and $0F) or $30;
    si := si + chr(b1) + chr(b2) + ' rev ';
    si := si + s[5];
    lblFirmwareValue1.Caption := si;
end;


procedure TMainForm.responseStatus(s : string);
var
  tmp1 : Byte;
begin
//BYTE 2
////////////////////////////////////////////////////////////////////////////////////
        tmp1 := Ord(s[2]);

        if ((tmp1 and $01) = $01) then lblAP1.font.color := clLime;
        if ((tmp1 and $01) = $00) then lblAP1.font.color := clBlack;

        if ((tmp1 and $02) = $02) then lblAP2.font.Color := clLime;
        if ((tmp1 and $02) = $00) then lblAP2.font.Color := clBlack;

        if ((tmp1 and $04) = $04) then lblFDSEL.font.Color := clLime;
        if ((tmp1 and $04) = $00) then lblFDSEL.font.Color := clBlack;

        if ((tmp1 and $08) = $08) then lblCOLL.font.Color := clLime;
        if ((tmp1 and $08) = $00) then lblCOLL.font.Color := clBlack;

        if ((tmp1 and $10) = $10) then lblCPL.font.Color := clLime;
        if ((tmp1 and $10) = $00) then lblCPL.font.Color := clBlack;

//BYTE 3
////////////////////////////////////////////////////////////////////////////////////
        tmp1 := Ord(s[3]);
        if ((tmp1 and $01) = $01) then lblSAS_ATT.font.color := clLime;
        if ((tmp1 and $01) = $00) then lblSAS_ATT.font.color := clBlack;

        if ((tmp1 and $02) = $02) then lblTEST.font.Color := clLime;
        if ((tmp1 and $02) = $00) then lblTEST.font.Color := clBlack;

        if ((tmp1 and $04) = $04) then lblRAD_ALT.font.Color := clLime;
        if ((tmp1 and $04) = $00) then lblRAD_ALT.font.Color := clBlack;

        if ((tmp1 and $08) = $08) then lblVELHLD.font.Color := clLime;
        if ((tmp1 and $08) = $00) then lblVELHLD.font.Color := clBlack;

end;

procedure TMainForm.responseIndicator(s : string);
var
  tmp1 : Byte;
begin
//BYTE 2
////////////////////////////////////////////////////////////////////////////////////
        tmp1 := Ord(s[2]);

        if ((tmp1 and $01) = $01) then lblAP1ON.Tag := 1 else lblAP1ON.Tag := 0;
        if ((tmp1 and $02) = $02) then lblAP2ON.Tag := 1 else lblAP2ON.Tag := 0;
        if ((tmp1 and $04) = $04) then lblFDSEL1ON.Tag := 1 else lblFDSEL1ON.Tag := 0;
        if ((tmp1 and $08) = $08) then lblFDSEL2ON.Tag := 1 else lblFDSEL2ON.Tag := 0;
        if ((tmp1 and $10) = $10) then lblCOLLON.Tag := 1 else lblCOLLON.Tag := 0;
        if ((tmp1 and $20) = $20) then lblCPLON.Tag := 1 else lblCPLON.Tag := 0;

//BYTE 3
////////////////////////////////////////////////////////////////////////////////////
        tmp1 := Ord(s[3]);

        if ((tmp1 and $01) = $01) then lblSASON.Tag := 1 else lblSASON.Tag := 0;
        if ((tmp1 and $02) = $02) then lblATTON.Tag := 1 else lblATTON.Tag := 0;
        if ((tmp1 and $04) = $04) then lblTESTON.Tag := 1 else lblTESTON.Tag := 0;
        if ((tmp1 and $08) = $08) then lblRAD_ALTON.Tag := 1 else lblRAD_ALTON.Tag := 0;
        if ((tmp1 and $10) = $10) then lblVELHLDON.Tag := 1 else lblVELHLDON.Tag := 0;

        ApplyDisplayDimming(CurrentDisplayBrightness);

end;


