procedure  TMainForm.decodeSerial(var sp1, sp2 : string);
var     // sp1 = gSerialBuffer    sp2 = gSerialBufferSMsg
  SMsg       : string;
  tmp1       : byte;
//  i          : integer;
begin
  sp1          := sp1 + sp2;   // add message to the buffer
  sp2          := '';          // clean out the message

  gByteCount  := length(sp1);  //set byte count to the length of the buffer
  SMsg := ' ';
  while(gByteCount >= gWholeMsg) do   // whole message is the minimum sized message I should recieve
    begin
      tmp1 := ord(sp1[1]);
      if (tmp1 = Status_Response)then
      begin
	      gWholeMsg  :=  Status_Response_Length;
	      if gByteCount < gWholeMsg then     // check to see if message is long enough
	      begin
		      Exit; // not enough then I need to  exit this function
        end
        else
        begin
		      decodeRecievedData(copy(sp1,1,Status_Response_Length));   // send it here cause I already set up this function
		      cleanRxBuffer(Status_Response_Length)                     // get rid of the message
        end;
      end
      else if (tmp1 = Firmware_Response) then
      begin
	      gWholeMsg  :=  Firmware_Response_Length;
	      if gByteCount < gWholeMsg then
	      begin
		      Exit;
	      end
          else
	      begin
		      decodeRecievedData(copy(sp1,1,Firmware_Response_Length));
		      cleanRxBuffer(Firmware_Response_Length)
	      end;
        end

      else if (tmp1 = Indicator_Request) then
      begin
           gWholeMsg := Indicator_Request_length;
           if gByteCount < gWholeMsg then
              begin
                   Exit;
              end
      else
      begin
           decodeRecievedData(copy(sp1,1,Indicator_Request_length));
           cleanRxBuffer(Indicator_Request_length)
      end;
    end

      else
      begin
	      SMsg := cleanRxBuffer(1);  // not start byte
      end;
    end

end;


procedure TMainForm.decodeRecievedData(s: string);
var
//  SMsg      : string;
//  lsLineNum : string;
  i         : integer;
//  count     : byte;
  DPtr      : pbyte;
  SPtr      : pbyte;

//0- reset 1- status 2-rtbuttons 3-rtpot 4-displays 5-firmware
begin
  if length(s) <> 0 then
  begin
    i := 1;
    while i <= length(s) do
    begin
      case Ord(s[i]) of
        Firmware_Response : begin  // program revision
          inc(NumberOfResponse);
          responseFirmware(s);
          i        := i + Status_Response_Length;
          end;//case = Status_Response
        Status_Response : begin  // switch status
          SPtr     := Addr(s[i]);
          DPtr     := Addr(Status_Response_Data[1]);
          CopyMemory(DPtr, SPtr, Status_Response_Length);
          inc(NumberOfResponse);
          responseStatus(s);
          i        := i + Status_Response_Length;
          end;//case = C1Response
        Indicator_Request : begin
          responseIndicator(s);
          i := i + Indicator_Request_length;
        end;
      Dimming_Request:
        begin
        if Length(s) >= 2 then
         begin
         UpdatingDimmingFromCmd := True;

         CurrentDisplayBrightness := Ord(s[2]);

         tkbDimming1.Position := CurrentDisplayBrightness;
         tkbDimming1Old := CurrentDisplayBrightness;

         lblDimming1.Caption := lblDimming1Cap + IntToStr(CurrentDisplayBrightness);

         ApplyDisplayDimming(CurrentDisplayBrightness);

         UpdatingDimmingFromCmd := False;
       end;

       i := i + Dimming_Request_Length + 1;
       end;
        else
          begin
          i          := i + 1;
          end;
      end;// case Ord(s[i]) of
    end;// while i <= length(s) do
  end;// if length(s) <> 0 then
  wrMemoWindow(cbxRDXWindowEnable,memoRx,lblReceived,RxWinLimit,RxPlace,'RX ','Lines Received : ',s);
end;

